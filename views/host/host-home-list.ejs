<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Syne:wght@400;500;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link rel="stylesheet" href="/css/output.css" />

<%- include('../partials/head') %>

<style>
  :root {
    --ink: #0d0d0d;
    --cream: #f5f0e8;
    --lime: #c8f04a;
    --lime-dark: #a8cc30;
    --muted: #6b6b6b;
    --border: #e4e0d8;
  }

  body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--ink); }
  .font-heading { font-family: 'Clash Display', sans-serif; }
  .font-display { font-family: 'Syne', sans-serif; }

  .task-card {
    background: white;
    border: 1.5px solid var(--border);
    border-radius: 26px;
    overflow: hidden;
    transition: transform 0.28s cubic-bezier(.22,.68,0,1.2), box-shadow 0.28s ease;
  }
  .task-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 48px rgba(0,0,0,0.08);
    border-color: #c5c0b8;
  }

  .task-card__img {
    width: 100%; height: 200px;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .task-card:hover .task-card__img { transform: scale(1.05); }

  /* Applicant row */
  .applicant-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-radius: 14px;
    background: #fafaf8;
    border: 1px solid var(--border);
    transition: background 0.15s;
  }
  .applicant-row:hover { background: #f0ede6; }

  .avatar-circle {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--lime);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Syne', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .status-pill {
    font-size: 0.68rem;
    font-weight: 700;
    font-family: 'Syne', sans-serif;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 9px;
    border-radius: 100px;
  }
  .status-applied  { background: #dbeafe; color: #1e40af; }
  .status-selected { background: #fef08a; color: #854d0e; }
  .status-done     { background: #dcfce7; color: #166534; }
  .status-default  { background: #f3f4f6; color: #6b7280; }

  .section-label {
    font-family: 'Syne', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .action-btn {
    font-family: 'Syne', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 8px 16px;
    border-radius: 10px;
    transition: all 0.15s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    border: none;
    cursor: pointer;
  }
  .btn-edit   { background: var(--ink); color: var(--lime); }
  .btn-edit:hover { background: #222; }
  .btn-delete { background: #fff0f0; color: #dc2626; border: 1px solid #fecaca; }
  .btn-delete:hover { background: #fee2e2; }

  /* No-applicants state */
  .no-applicants {
    padding: 14px 18px;
    border: 1.5px dashed var(--border);
    border-radius: 14px;
    text-align: center;
    color: var(--muted);
    font-size: 0.82rem;
  }

  /* fade up animation */
  .task-card { opacity: 0; animation: fadeUp 0.5s ease forwards; }
  .task-card:nth-child(1) { animation-delay: 0.1s; }
  .task-card:nth-child(2) { animation-delay: 0.2s; }
  .task-card:nth-child(3) { animation-delay: 0.3s; }
  .task-card:nth-child(4) { animation-delay: 0.4s; }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

</head>

<body class="min-h-screen">

<%- include('../partials/header', { isLoggedIn: isLoggedIn, user: user }) %>

<main class="max-w-7xl mx-auto px-5 sm:px-8 pt-28 pb-28">

  <!-- PAGE HEADER -->
  <section class="mb-10 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
    <div>
      <div class="inline-flex items-center gap-2 bg-white border border-[var(--border)] px-4 py-1.5 rounded-full text-xs font-semibold text-gray-500 shadow-sm">
        <i class="fa-solid fa-bars-progress text-[var(--lime-dark)]"></i> Host Dashboard
      </div>
      <h1 class="font-heading text-4xl sm:text-5xl font-bold mt-4 tracking-tight text-gray-900">
        Your Posted Tasks
      </h1>
      <p class="mt-1 text-gray-500 text-sm">Manage your tasks and see which students have applied.</p>
    </div>

    <!-- STATS STRIP -->
    <div class="flex gap-3">
      <div class="bg-white border border-[var(--border)] rounded-2xl px-5 py-3 text-center shadow-sm">
        <p class="font-heading text-2xl font-bold text-gray-900"><%= registeredHomes.length %></p>
        <p class="section-label mt-0.5">Tasks Posted</p>
      </div>
      <div class="bg-white border border-[var(--border)] rounded-2xl px-5 py-3 text-center shadow-sm">
        <p class="font-heading text-2xl font-bold text-gray-900">
          <%= registeredHomes.reduce((acc, h) => acc + (h.bookings ? h.bookings.length : 0), 0) %>
        </p>
        <p class="section-label mt-0.5">Applicants</p>
      </div>
    </div>
  </section>

  <!-- POST NEW TASK CTA -->
  <div class="mb-8">
    <a href="/add-home" class="inline-flex items-center gap-2 bg-[var(--ink)] text-[var(--lime)] font-display font-bold text-sm uppercase tracking-wider px-6 py-3 rounded-2xl hover:bg-[#222] transition shadow-lg">
      <i class="fa-solid fa-plus text-xs"></i> Post New Task
    </a>
  </div>

  <% if (registeredHomes.length === 0) { %>
    <!-- EMPTY STATE -->
    <div class="max-w-md mx-auto text-center border-2 border-dashed border-[var(--border)] rounded-[28px] p-12 mt-10">
      <div class="text-5xl mb-4">📋</div>
      <h2 class="font-heading text-2xl font-bold text-gray-800">No tasks posted yet</h2>
      <p class="text-sm text-gray-500 mt-2">Post your first micro-task and start getting applicants!</p>
      <a href="/add-home" class="inline-block mt-8 bg-[var(--ink)] text-[var(--lime)] font-display font-bold text-sm uppercase tracking-wider px-8 py-3 rounded-xl hover:bg-[#222] transition">
        Post a Task →
      </a>
    </div>

  <% } else { %>

    <!-- TASK GRID -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

      <% registeredHomes.forEach(home => { %>
      <div class="task-card">

        <!-- IMAGE -->
        <div class="relative overflow-hidden" style="height:200px">
          <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="task-card__img">
          <span class="absolute top-4 right-4 bg-black/70 text-white backdrop-blur px-3 py-1 rounded-full text-sm font-bold">
            ₹ <%= home.price %>
          </span>
          <span class="absolute top-4 left-4 bg-white text-xs font-bold px-3 py-1 rounded-full shadow">
            ⭐ <%= home.rating %>
          </span>
          <span class="absolute bottom-4 left-4 bg-white/95 border border-[var(--border)] text-gray-700 text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full shadow-sm">
            <%= home.propertytype %>
          </span>
        </div>

        <!-- BODY -->
        <div class="p-6 space-y-4">

          <!-- TASK INFO -->
          <div>
            <h3 class="font-heading text-xl font-bold text-gray-900 leading-tight"><%= home.houseName %></h3>
            <p class="text-xs text-gray-400 flex items-center gap-1 mt-1.5">
              <i class="fa-solid fa-location-dot"></i> <%= home.location %>
              <span class="mx-2 text-gray-300">·</span>
              <i class="fa-solid fa-users"></i> Needed: <%= home.maxguest %>
            </p>
          </div>

          <p class="text-sm text-gray-500 leading-relaxed line-clamp-2"><%= home.description %></p>

          <!-- ─── APPLICANTS SECTION ─── -->
          <div>
            <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
              <p class="section-label flex items-center gap-1.5">
                <i class="fa-solid fa-user-check text-[var(--lime-dark)]"></i>
                Applicants
                <span class="ml-1 bg-[var(--ink)] text-[var(--lime)] text-[10px] font-bold px-2 py-0.5 rounded-full">
                  <%= home.bookings ? home.bookings.length : 0 %>
                </span>
              </p>
              <% if (home.bookings && home.bookings.length > 1) { %>
                <div class="flex items-center gap-1">
                  <span class="text-[9px] uppercase font-bold text-gray-400">Sort:</span>
                  <button type="button" onclick="sortApplicants('<%= home._id %>', 'distance')" data-criteria="distance" class="sort-btn-<%= home._id %> text-[9px] bg-gray-100 text-gray-600 hover:bg-gray-200 px-2 py-0.5 rounded-md font-semibold transition">Distance</button>
                  <button type="button" onclick="sortApplicants('<%= home._id %>', 'price')" data-criteria="price" class="sort-btn-<%= home._id %> text-[9px] bg-gray-100 text-gray-600 hover:bg-gray-200 px-2 py-0.5 rounded-md font-semibold transition">Price</button>
                </div>
              <% } %>
            </div>

            <% if (!home.bookings || home.bookings.length === 0) { %>
              <div class="no-applicants">
                <i class="fa-regular fa-clock mr-1"></i> No applicants yet — waiting for students to apply.
              </div>

            <% } else { %>
              <div id="bookings-container-<%= home._id %>" class="space-y-2 max-h-48 overflow-y-auto pr-1">
                <% home.bookings.forEach(booking => { %>
                  <div class="applicant-row" data-price="<%= booking.user ? booking.user.expectedPrice || 0 : 0 %>" data-distance="<%= booking.user ? booking.user.distance || 0 : 0 %>">

                    <!-- AVATAR -->
                    <div class="avatar-circle">
                      <%= booking.user ? booking.user.firstName.charAt(0).toUpperCase() : '?' %>
                    </div>

                    <!-- STUDENT INFO -->
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-semibold text-gray-900 truncate">
                        <%= booking.user ? booking.user.firstName + ' ' + (booking.user.lastName || '') : 'Unknown Student' %>
                      </p>
                      <div class="flex items-center gap-1 mt-1 flex-wrap">
                        <span class="inline-flex items-center gap-0.5 bg-gray-100 text-gray-500 text-[9px] px-1.5 py-0.5 rounded-md font-medium">
                          <i class="fa-solid fa-money-bill-wave text-emerald-600"></i> ₹<%= booking.user ? booking.user.expectedPrice || 0 : 0 %>/hr
                        </span>
                        <span class="inline-flex items-center gap-0.5 bg-gray-100 text-gray-500 text-[9px] px-1.5 py-0.5 rounded-md font-medium">
                          <i class="fa-solid fa-location-arrow text-blue-500"></i> <%= booking.user ? booking.user.distance || 0 : 0 %> km
                        </span>
                        <% if (booking.user && booking.user.completedTasks > 0) { %>
                          <span class="inline-flex items-center gap-0.5 bg-amber-50 text-amber-700 border border-amber-200 text-[9px] px-1.5 py-0.5 rounded-md font-medium">
                            <i class="fa-solid fa-circle-check text-amber-500"></i> <%= booking.user.completedTasks %> Done
                          </span>
                        <% } %>
                        <% if (booking.user && booking.user.location) { %>
                          <span class="inline-flex items-center gap-0.5 bg-indigo-50 text-indigo-600 border border-indigo-100 text-[9px] px-1.5 py-0.5 rounded-md font-medium">
                            <i class="fa-solid fa-map-pin text-indigo-500"></i> <%= booking.user.location %>
                          </span>
                        <% } %>
                      </div>
                    </div>

                    <!-- STATUS & ACTION -->
                    <div class="text-right flex-shrink-0 flex flex-col items-end gap-1.5">
                      <span class="status-pill <%= booking.status === 'Applied' ? 'status-applied' : booking.status === 'Selected' ? 'status-selected' : booking.status === 'Completed' ? 'status-done' : 'status-default' %>">
                        <%= booking.status || 'Pending' %>
                      </span>
                      <% if (booking.status === 'Applied') { %>
                        <form action="/bookings/select/<%= booking._id %>" method="POST">
                          <button type="submit" class="text-[9px] bg-[var(--ink)] text-[var(--lime)] hover:bg-[#222] font-display font-bold uppercase tracking-wider px-2 py-1 rounded-md transition shadow-sm cursor-pointer">
                            Select
                          </button>
                        </form>
                      <% } %>
                    </div>

                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>

          <!-- ACTIONS -->
          <div class="flex items-center gap-2 pt-4 border-t border-[var(--border)]">
            <a href="/edithome/<%= home._id %>?editing=true" class="action-btn btn-edit flex-1 justify-center text-xs py-2 rounded-xl">
              <i class="fa-solid fa-pen text-[10px]"></i> Edit
            </a>
            <!-- Complete triggers modal instead of direct submit -->
            <button
              type="button"
              onclick="openCompleteModal('<%= home._id %>', '<%= home.houseName.replace(/'/g, "\\'" ) %>')"
              class="action-btn w-full flex-1 justify-center bg-emerald-600 hover:bg-emerald-700 text-white text-xs border-none font-bold py-2 rounded-xl"
            >
              <i class="fa-solid fa-circle-check text-[10px]"></i> Complete
            </button>
            <form action="/delete-home/<%= home._id %>" method="POST" class="flex-1">
              <button type="submit" class="action-btn btn-delete w-full justify-center text-xs py-2 rounded-xl">
                <i class="fa-solid fa-trash text-[10px]"></i> Delete
              </button>
            </form>
          </div>

        </div>
      </div>
      <% }) %>

    </div>
  <% } %>

</main>

<!-- ─── COMPLETE TASK CONFIRMATION MODAL ─── -->
<div id="completeModal" class="fixed inset-0 z-[9999] flex items-center justify-center px-4" style="display:none !important">
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeCompleteModal()"></div>

  <!-- Modal Card -->
  <div class="relative bg-white rounded-[28px] shadow-2xl max-w-md w-full p-8 z-10 animate-modal">
    <!-- Icon -->
    <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-5">
      <i class="fa-solid fa-circle-check text-emerald-600 text-2xl"></i>
    </div>

    <h2 class="font-heading text-2xl font-bold text-gray-900 text-center mb-1">Mark Task Complete?</h2>
    <p id="completeModalSubtitle" class="text-sm text-gray-500 text-center mb-6">This will permanently remove the task and all applicants.</p>

    <div class="bg-amber-50 border border-amber-200 rounded-2xl p-4 mb-6 text-sm text-amber-800">
      <p class="font-semibold flex items-center gap-2 mb-1">
        <i class="fa-solid fa-triangle-exclamation text-amber-500"></i> What happens next:
      </p>
      <ul class="list-disc pl-5 space-y-1 text-xs text-amber-700">
        <li>The task will be <strong>permanently deleted</strong></li>
        <li>All applicants will be <strong>removed</strong></li>
        <li>The <strong>selected student's</strong> completed-tasks count increases by 1</li>
      </ul>
    </div>

    <div class="flex gap-3">
      <button
        type="button"
        onclick="closeCompleteModal()"
        class="flex-1 py-3 rounded-xl border border-[var(--border)] text-gray-600 font-display font-bold text-sm uppercase tracking-wider hover:bg-gray-50 transition"
      >
        Cancel
      </button>
      <!-- Hidden real form -->
      <form id="completeModalForm" action="" method="POST" class="flex-1">
        <button
          type="submit"
          class="w-full py-3 rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white font-display font-bold text-sm uppercase tracking-wider transition shadow-md"
        >
          <i class="fa-solid fa-check mr-1"></i> Yes, Complete
        </button>
      </form>
    </div>
  </div>
</div>

<style>
  @keyframes modalIn {
    from { opacity: 0; transform: translateY(20px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0)  scale(1);    }
  }
  .animate-modal { animation: modalIn 0.28s cubic-bezier(0.16,1,0.3,1) forwards; }
</style>

<script>
  function sortApplicants(homeId, criteria) {
    const container = document.getElementById(`bookings-container-${homeId}`);
    if (!container) return;

    const rows = Array.from(container.querySelectorAll('.applicant-row'));
    rows.sort((a, b) => {
      const valA = parseFloat(a.getAttribute(`data-${criteria}`)) || 0;
      const valB = parseFloat(b.getAttribute(`data-${criteria}`)) || 0;
      return valA - valB;
    });

    // Re-append sorted elements
    rows.forEach(row => container.appendChild(row));

    // Toggle active styling on buttons
    const buttons = document.querySelectorAll(`.sort-btn-${homeId}`);
    buttons.forEach(btn => {
      if (btn.getAttribute('data-criteria') === criteria) {
        btn.classList.remove('bg-gray-100', 'text-gray-600');
        btn.classList.add('bg-[var(--ink)]', 'text-[var(--lime)]');
      } else {
        btn.classList.add('bg-gray-100', 'text-gray-600');
        btn.classList.remove('bg-[var(--ink)]', 'text-[var(--lime)]');
      }
    });
  }

  // ── Complete Modal ────────────────────────────────
  const completeModal = document.getElementById('completeModal');
  const completeModalForm = document.getElementById('completeModalForm');
  const completeModalSubtitle = document.getElementById('completeModalSubtitle');

  function openCompleteModal(homeId, taskName) {
    completeModalForm.action = `/complete-home/${homeId}`;
    completeModalSubtitle.textContent =
      `"${taskName}" will be permanently closed and removed.`;
    completeModal.style.removeProperty('display');
    completeModal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeCompleteModal() {
    completeModal.style.display = 'none';
    document.body.style.overflow = '';
  }

  // Close on Escape key
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeCompleteModal();
  });
</script>

</body>
</html>