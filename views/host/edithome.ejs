<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= editing ? "Edit Task" : "Post a Task" %> • Campus Gigs</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/output.css" />
    <style>
      body {
        font-family: 'Plus Jakarta Sans', sans-serif;
      }
      .font-heading {
        font-family: 'Outfit', sans-serif;
      }
    </style>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-700 selection:bg-indigo-100 selection:text-indigo-900">

    <!-- NAVBAR HEADER -->
    <%- include('../partials/header', { isLoggedIn: isLoggedIn, user: user }) %>

    <!-- MAIN CONTENT -->
    <main class="pt-32 pb-20 flex justify-center px-4 sm:px-6">
      <div class="w-full max-w-2xl bg-white border border-slate-100 rounded-3xl shadow-xl p-8 sm:p-10">

        <!-- Heading -->
        <div class="text-center mb-10">
          <h1 class="font-heading text-4xl font-extrabold text-slate-900 mb-3">
            <%= editing ? "Edit your task" : "Post a new task" %>
          </h1>
          <p class="text-slate-500 text-sm">
            Share small tasks and let students help you quickly.
          </p>
        </div>

        <% if (locals.errorMessage) { %>
          <div class="mb-6 p-4 bg-rose-50 border-l-4 border-rose-500 rounded-r-xl flex items-center gap-3 shadow-sm text-sm text-rose-800 font-medium animate-pulse">
            <svg class="w-5 h-5 text-rose-600 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
            </svg>
            <p><%= errorMessage %></p>
          </div>
        <% } %>

        <!-- FORM -->
        <form 
          action="/<%= editing ? "edithome" : "add-home" %>" 
          method="POST"
          enctype="multipart/form-data"
          class="space-y-6"
        >

          <input type="hidden" name="id" value="<%= home._id || '' %>" />

          <!-- TASK TITLE -->
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">
              Task Title
            </label>
            <input
              type="text"
              name="houseName"
              value="<%= home.houseName || '' %>"
              placeholder="e.g. Need help with notes printing"
              required
              class="w-full px-4 py-3 border border-slate-200 rounded-2xl bg-white text-slate-900 placeholder-slate-400 focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100 transition duration-200 text-sm"
            />
          </div>

          <!-- PAYMENT & RATING -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">
                Payment (₹)
              </label>
              <input
                type="number"
                name="price"
                value="<%= home.price || '' %>"
                placeholder="e.g. 100"
                required
                class="w-full px-4 py-3 border border-slate-200 rounded-2xl bg-white text-slate-900 placeholder-slate-400 focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100 transition duration-200 text-sm"
              />
            </div>

            <div>
              <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">
                Rating (0 - 5)
              </label>
              <input
                type="number"
                step="0.1"
                max="5"
                name="rating"
                value="<%= home.rating || '' %>"
                placeholder="e.g. 4.5"
                required
                class="w-full px-4 py-3 border border-slate-200 rounded-2xl bg-white text-slate-900 placeholder-slate-400 focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100 transition duration-200 text-sm"
              />
            </div>

            <!-- PEOPLE NEEDED -->
            <div>
              <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">
                People Needed
              </label>
              <input
                type="number"
                name="maxguest"
                min="1"
                value="<%= home.maxguest || home.maxGuests || '' %>"
                placeholder="e.g. 2"
                required
                class="w-full px-4 py-3 border border-slate-200 rounded-2xl bg-white text-slate-900 placeholder-slate-400 focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100 transition duration-200 text-sm"
              />
            </div>

            <!-- TASK TYPE -->
            <div>
              <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">
                Task Type
              </label>
              <select
                name="propertytype"
                required
                class="w-full px-4 py-3 border border-slate-200 rounded-2xl bg-white text-slate-900 focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100 transition duration-200 text-sm"
              >
                <option value="">Select task type</option>
                <option value="Delivery" <%= home.propertytype === 'Delivery' ? 'selected' : '' %>>Delivery</option>
                <option value="Academic Help" <%= home.propertytype === 'Academic Help' ? 'selected' : '' %>>Academic Help</option>
                <option value="Cleaning" <%= home.propertytype === 'Cleaning' ? 'selected' : '' %>>Cleaning</option>
                <option value="Tech Help" <%= home.propertytype === 'Tech Help' ? 'selected' : '' %>>Tech Help</option>
                <option value="Design" <%= home.propertytype === 'Design' ? 'selected' : '' %>>Design</option>
                <option value="Other" <%= home.propertytype === 'Other' ? 'selected' : '' %>>Other</option>
              </select>
            </div>
          </div>

          <!-- LOCATION -->
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">
              Location (on campus)
            </label>
            <input
              type="text"
              name="location"
              value="<%= home.location || '' %>"
              placeholder="e.g. Hostel Block A"
              required
              class="w-full px-4 py-3 border border-slate-200 rounded-2xl bg-white text-slate-900 placeholder-slate-400 focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100 transition duration-200 text-sm"
            />
          </div>

          <!-- DESCRIPTION -->
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">
              Task Description
            </label>
            <textarea
              name="description"
              rows="4"
              required
              placeholder="Explain what needs to be done clearly..."
              class="w-full px-4 py-3 border border-slate-200 rounded-2xl bg-white text-slate-900 placeholder-slate-400 focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100 transition duration-200 text-sm resize-none"
            ><%= home.description || '' %></textarea>
          </div>

          <!-- FILES UPLOAD (images + PDFs + docs) -->
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">
              Attachments — Images, PDFs, Documents <span class="text-slate-300 font-normal">(up to 10 files · 20 MB each)</span>
            </label>

            <!-- Drop Zone -->
            <div
              id="drop-zone"
              onclick="document.getElementById('file-input').click()"
              class="relative border-2 border-dashed border-slate-200 hover:border-indigo-400 rounded-2xl p-8 text-center cursor-pointer transition-all duration-200 bg-slate-50 hover:bg-indigo-50"
            >
              <input
                id="file-input"
                type="file"
                name="files"
                multiple
                accept="image/*,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.zip,.rar"
                class="hidden"
                onchange="handleFiles(this.files)"
              />
              <div id="drop-placeholder">
                <div class="w-14 h-14 rounded-2xl bg-white border border-slate-200 flex items-center justify-center mx-auto mb-3 shadow-sm">
                  <i class="fa-solid fa-cloud-arrow-up text-2xl text-indigo-400"></i>
                </div>
                <p class="text-sm font-semibold text-slate-600">Click to browse or drag & drop files here</p>
                <p class="text-xs text-slate-400 mt-1">Images, PDFs, Word, Excel, PowerPoint, ZIP — any type</p>
              </div>
            </div>

            <!-- Live Preview Grid -->
            <div id="preview-grid" class="mt-4 grid grid-cols-2 sm:grid-cols-3 gap-3 hidden"></div>

            <!-- Existing files when editing -->
            <% if (editing && home.photos && home.photos.length > 0) { %>
              <div class="mt-4">
                <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Current Images</p>
                <div class="grid grid-cols-3 sm:grid-cols-4 gap-2">
                  <% home.photos.forEach(p => { %>
                    <div class="relative rounded-xl overflow-hidden h-20 bg-slate-100 border border-slate-200">
                      <img src="<%= p %>" class="w-full h-full object-cover" />
                    </div>
                  <% }) %>
                </div>
              </div>
            <% } %>
            <% if (editing && home.attachments && home.attachments.length > 0) { %>
              <div class="mt-3">
                <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Current Attachments</p>
                <div class="space-y-1.5">
                  <% home.attachments.forEach(a => { %>
                    <a href="<%= a.url %>" target="_blank" class="flex items-center gap-2 text-xs text-indigo-600 hover:underline bg-indigo-50 border border-indigo-100 rounded-xl px-3 py-2">
                      <i class="fa-solid fa-file-arrow-down text-indigo-400"></i>
                      <%= a.name %>
                    </a>
                  <% }) %>
                </div>
              </div>
            <% } %>
          </div>

          <style>
            #drop-zone.drag-over {
              border-color: #6366f1;
              background: #eef2ff;
            }
            .preview-item {
              position: relative;
              border-radius: 14px;
              overflow: hidden;
              border: 1px solid #e2e8f0;
              background: #f8fafc;
              animation: previewPop 0.2s cubic-bezier(.34,1.56,.64,1) both;
            }
            @keyframes previewPop {
              from { opacity: 0; transform: scale(0.88); }
              to   { opacity: 1; transform: scale(1); }
            }
            .preview-remove {
              position: absolute; top: 4px; right: 4px;
              width: 20px; height: 20px;
              background: rgba(15,23,42,.7);
              color: white;
              border-radius: 50%;
              border: none;
              cursor: pointer;
              font-size: 10px;
              display: flex; align-items: center; justify-content: center;
            }
          </style>

          <script>
            const dropZone = document.getElementById('drop-zone');
            const fileInput = document.getElementById('file-input');
            const previewGrid = document.getElementById('preview-grid');
            let selectedFiles = [];

            // Drag & drop support
            dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
            dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
            dropZone.addEventListener('drop', e => {
              e.preventDefault();
              dropZone.classList.remove('drag-over');
              handleFiles(e.dataTransfer.files);
            });

            function handleFiles(newFiles) {
              const arr = Array.from(newFiles);
              if (selectedFiles.length + arr.length > 10) {
                alert('Maximum 10 files allowed!');
                return;
              }
              selectedFiles = [...selectedFiles, ...arr];
              updateFileInput();
              renderPreviews();
            }

            function updateFileInput() {
              // Rebuild the FileList-like object via DataTransfer
              const dt = new DataTransfer();
              selectedFiles.forEach(f => dt.items.add(f));
              fileInput.files = dt.files;
            }

            function removeFile(index) {
              selectedFiles.splice(index, 1);
              updateFileInput();
              renderPreviews();
            }

            function renderPreviews() {
              previewGrid.innerHTML = '';
              if (selectedFiles.length === 0) {
                previewGrid.classList.add('hidden');
                return;
              }
              previewGrid.classList.remove('hidden');

              selectedFiles.forEach((file, i) => {
                const item = document.createElement('div');
                item.className = 'preview-item';

                const removeBtn = `<button type="button" class="preview-remove" onclick="removeFile(${i})">✕</button>`;

                if (file.type.startsWith('image/')) {
                  const url = URL.createObjectURL(file);
                  item.innerHTML = `
                    <img src="${url}" class="w-full h-24 object-cover" />
                    <p class="text-[10px] text-slate-500 truncate px-2 py-1">${file.name}</p>
                    ${removeBtn}
                  `;
                } else {
                  // File icon for non-images
                  const ext = file.name.split('.').pop().toUpperCase();
                  const iconMap = { PDF: '🔴', DOC: '🔵', DOCX: '🔵', XLS: '🟢', XLSX: '🟢', PPT: '🟠', PPTX: '🟠', ZIP: '🟤', RAR: '🟤' };
                  const icon = iconMap[ext] || '📄';
                  item.innerHTML = `
                    <div class="flex flex-col items-center justify-center h-24 gap-2 px-2">
                      <span class="text-3xl">${icon}</span>
                      <span class="text-[9px] font-bold bg-slate-200 text-slate-600 px-2 py-0.5 rounded-full">${ext}</span>
                    </div>
                    <p class="text-[10px] text-slate-500 truncate px-2 pb-2">${file.name}</p>
                    ${removeBtn}
                  `;
                }
                previewGrid.appendChild(item);
              });
            }
          </script>

          <!-- SUBMIT -->
          <div class="pt-4">
            <button
              type="submit"
              class="w-full py-4 rounded-2xl font-heading text-sm font-bold uppercase tracking-wider text-white bg-gradient-to-r from-indigo-600 to-emerald-500 hover:shadow-indigo-500/20 hover:shadow-lg hover:-translate-y-0.5 transition duration-200 cursor-pointer"
            >
              <%= editing ? "Update Task" : "Post Task" %>
            </button>
          </div>

        </form>
      </div>
    </main>

    <%- include('../partials/chatbot-widget') %>

  </body>
</html>