<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Post a Task</title>

    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body
    class="min-h-screen bg-gradient-to-b from-[#f0fdf4] via-white to-[#f7f7f7] font-sans"
  >
    <!-- HEADER -->
    <header>
      <nav
        class="w-full fixed top-0 left-0 z-50 backdrop-blur-md bg-[#16a34a]/90 shadow-lg"
      >
        <div
          class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center"
        >
          <!-- LOGO -->
          <a
            href="/"
            class="flex items-center gap-2 text-white font-semibold text-lg tracking-wide group"
          >
            <svg
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-6 h-6 group-hover:scale-110 transition"
            >
              <path
                d="M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7z"
              />
            </svg>
            <span>CampusTasks</span>
          </a>

          <!-- NAV -->
          <div class="flex items-center gap-6">
            <a href="/homes" class="nav-btn">Tasks</a>
            <a href="/favourites" class="nav-btn">Saved</a>
            <a href="/bookings" class="nav-btn">My Tasks</a>
            <a href="/host-home-list" class="nav-btn">Dashboard</a>
          </div>
        </div>
      </nav>
    </header>

    <!-- MAIN -->
    <main class="pt-32 pb-20 flex justify-center">
      <div class="w-full max-w-2xl bg-white rounded-2xl shadow-xl p-10">

        <!-- Heading -->
        <div class="text-center mb-10">
          <h1 class="text-4xl font-semibold text-[#222] mb-3">
            <%= editing ? "Edit your task" : "Post a new task" %>
          </h1>
          <p class="text-gray-500 text-sm">
            Share small tasks and let students help you quickly.
          </p>
        </div>

        <% if (locals.errorMessage) { %>
          <div class="mb-6 p-4 bg-rose-50 border-l-4 border-rose-500 rounded-r-xl flex items-center gap-3 shadow-sm text-sm text-rose-800 font-medium">
            <svg class="w-5 h-5 text-rose-600 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            <p><%= errorMessage %></p>
          </div>
        <% } %>

        <!-- FORM -->
        <form 
          action="/<%= editing ? "edithome" : "add-home" %>" 
          method="POST"
          enctype="multipart/form-data"
          class="space-y-6"
        >

          <input type="hidden" name="id" value="<%= home._id || '' %>" />

          <!-- TASK TITLE -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Task Title
            </label>
            <input
              type="text"
              name="houseName"
              value="<%= home.houseName || '' %>"
              placeholder="e.g. Need help with notes printing"
              required
              class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-green-500 focus:outline-none"
            />
          </div>

          <!-- PAYMENT & RATING -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                Payment (₹)
              </label>
              <input
                type="number"
                name="price"
                value="<%= home.price || '' %>"
                placeholder="e.g. 100"
                required
                class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-green-500 focus:outline-none"
              />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                Rating (0 - 5)
              </label>
              <input
                type="number"
                step="0.1"
                max="5"
                name="rating"
                value="<%= home.rating || '' %>"
                placeholder="e.g. 4.5"
                required
                class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-green-500 focus:outline-none"
              />
            </div>

            <!-- PEOPLE NEEDED -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                People Needed
              </label>
              <input
                type="number"
                name="maxguest"
                min="1"
                value="<%= home.maxguest || home.maxGuests || '' %>"
                placeholder="e.g. 2"
                required
                class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-green-500 focus:outline-none"
              />
            </div>

            <!-- TASK TYPE -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                Task Type
              </label>
              <select
                name="propertytype"
                required
                class="w-full px-4 py-3 border rounded-lg bg-white focus:ring-2 focus:ring-green-500 focus:outline-none"
              >
                <option value="">Select task type</option>
                <option value="Delivery" <%= home.propertytype === 'Delivery' ? 'selected' : '' %>>Delivery</option>
                <option value="Academic Help" <%= home.propertytype === 'Academic Help' ? 'selected' : '' %>>Academic Help</option>
                <option value="Cleaning" <%= home.propertytype === 'Cleaning' ? 'selected' : '' %>>Cleaning</option>
                <option value="Tech Help" <%= home.propertytype === 'Tech Help' ? 'selected' : '' %>>Tech Help</option>
                <option value="Design" <%= home.propertytype === 'Design' ? 'selected' : '' %>>Design</option>
                <option value="Other" <%= home.propertytype === 'Other' ? 'selected' : '' %>>Other</option>
              </select>
            </div>
          </div>

          <!-- LOCATION -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Location (on campus)
            </label>
            <input
              type="text"
              name="location"
              value="<%= home.location || '' %>"
              placeholder="e.g. Hostel Block A"
              required
              class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-green-500 focus:outline-none"
            />
          </div>

          <!-- DESCRIPTION -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Task Description
            </label>
            <textarea
              name="description"
              rows="4"
              required
              placeholder="Explain what needs to be done clearly..."
              class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-green-500 focus:outline-none resize-none"
            ><%= home.description || '' %></textarea>
          </div>

          <!-- IMAGE -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Task Image (optional)
            </label>
            <input
              type="file"
              name="photo"
              accept="image/jpg, image/jpeg, image/png"
              class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-green-500 focus:outline-none"
            />
          </div>

          <!-- SUBMIT -->
          <div class="pt-4">
            <button
              type="submit"
              class="w-full py-3 rounded-lg font-medium text-white bg-gradient-to-r from-green-500 to-emerald-600 hover:shadow-lg hover:-translate-y-0.5 transition"
            >
              <%= editing ? "Update Task" : "Post Task" %>
            </button>
          </div>

        </form>
      </div>
    </main>

  </body>
</html>