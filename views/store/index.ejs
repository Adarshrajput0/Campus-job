<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap"
  rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<link rel="stylesheet" href="/css/output.css" />

<%- include('../partials/head', { pageTitle: 'Campus Job Portal' }) %>

  <style>
    :root {
      --ink: #0a0a0f;
      --ink-muted: #4a4a5a;
      --ink-faint: #9090a8;
      --surface: #ffffff;
      --surface-off: #f5f5f7;
      --surface-mid: #ededf2;
      --accent: #5b4cff;
      --accent-glow: rgba(91, 76, 255, 0.18);
      --accent-tint: #f0eeff;
      --green: #00c16a;
      --green-tint: #e8faf2;
      --amber: #f5a623;
      --border: rgba(0, 0, 0, 0.07);
      --border-hover: rgba(91, 76, 255, 0.25);
      --radius-sm: 10px;
      --radius-md: 16px;
      --radius-lg: 24px;
      --radius-xl: 32px;
      --shadow-card: 0 2px 12px rgba(0, 0, 0, 0.04), 0 0 0 1px rgba(0, 0, 0, 0.05);
      --shadow-hover: 0 16px 40px rgba(91, 76, 255, 0.13), 0 0 0 1px rgba(91, 76, 255, 0.18);
      --shadow-btn: 0 8px 24px rgba(91, 76, 255, 0.3);
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--surface-off);
      color: var(--ink);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    .font-display {
      font-family: 'Syne', sans-serif;
    }

    /* ─── Layout ─── */
    .page-wrap {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 40px;
    }

    /* ─── Hero grid bg ─── */
    .hero-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(0, 0, 0, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 0, 0, 0.04) 1px, transparent 1px);
      background-size: 48px 48px;
      mask-image: radial-gradient(ellipse 80% 60% at 30% 20%, black 30%, transparent 70%);
      -webkit-mask-image: radial-gradient(ellipse 80% 60% at 30% 20%, black 30%, transparent 70%);
    }

    /* ─── Orbs ─── */
    .orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.5;
      pointer-events: none;
      z-index: 0;
    }

    .orb-1 {
      width: 600px;
      height: 600px;
      background: #c5beff;
      top: -200px;
      left: -150px;
    }

    .orb-2 {
      width: 400px;
      height: 400px;
      background: #b8f5d8;
      bottom: -100px;
      right: -80px;
    }

    /* ─── Breadcrumb / eyebrow ─── */
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 100px;
      padding: 6px 14px 6px 10px;
      font-size: 12px;
      font-weight: 500;
      color: var(--ink-muted);
      box-shadow: var(--shadow-card);
    }

    .eyebrow-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--green);
      box-shadow: 0 0 0 3px var(--green-tint);
      animation: pulse-dot 2s infinite;
    }

    @keyframes pulse-dot {

      0%,
      100% {
        box-shadow: 0 0 0 3px var(--green-tint);
      }

      50% {
        box-shadow: 0 0 0 6px rgba(0, 193, 106, 0.1);
      }
    }

    /* ─── Hero heading ─── */
    .hero-h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(3rem, 6vw, 5.5rem);
      font-weight: 800;
      line-height: 1.02;
      letter-spacing: -0.03em;
      color: var(--ink);
    }

    .hero-h1 mark {
      background: none;
      -webkit-background-clip: unset;
      color: var(--accent);
      position: relative;
    }

    .hero-h1 mark::after {
      content: '';
      position: absolute;
      left: 0;
      right: 0;
      bottom: 2px;
      height: 3px;
      background: var(--accent);
      border-radius: 100px;
      opacity: 0.35;
    }

    /* ─── CTA Buttons ─── */
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--ink);
      color: #fff;
      font-family: 'Syne', sans-serif;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      padding: 14px 28px;
      border-radius: var(--radius-md);
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.22s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .btn-primary:hover {
      background: var(--accent);
      box-shadow: var(--shadow-btn);
      transform: translateY(-2px);
    }

    .btn-primary .arrow-icon {
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      transition: transform 0.2s ease;
    }

    .btn-primary:hover .arrow-icon {
      transform: translateX(2px);
    }

    .btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--surface);
      color: var(--ink);
      font-size: 13px;
      font-weight: 500;
      padding: 14px 24px;
      border-radius: var(--radius-md);
      border: 1px solid var(--border);
      cursor: pointer;
      text-decoration: none;
      transition: all 0.2s ease;
      box-shadow: var(--shadow-card);
    }

    .btn-ghost:hover {
      border-color: var(--border-hover);
      color: var(--accent);
      transform: translateY(-1px);
      box-shadow: 0 8px 24px rgba(91, 76, 255, 0.08);
    }

    /* ─── Stats strip ─── */
    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 24px 20px;
      text-align: center;
      box-shadow: var(--shadow-card);
      transition: all 0.25s ease;
    }

    .stat-card:hover {
      border-color: var(--border-hover);
      box-shadow: var(--shadow-hover);
      transform: translateY(-3px);
    }

    .stat-val {
      font-family: 'Syne', sans-serif;
      font-size: 2rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1;
    }

    .stat-label {
      font-size: 10.5px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink-faint);
      margin-top: 6px;
    }

    /* ─── Section header ─── */
    .section-rule {
      display: inline-block;
      width: 4px;
      height: 22px;
      background: var(--accent);
      border-radius: 100px;
      flex-shrink: 0;
    }

    /* ─── Filter pills ─── */
    .pill-filter {
      cursor: pointer;
      font-size: 12.5px;
      font-weight: 600;
      padding: 8px 20px;
      border-radius: 100px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--ink-muted);
      transition: all 0.2s ease;
      white-space: nowrap;
    }

    .pill-filter:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .pill-filter.active {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
      box-shadow: 0 6px 18px rgba(91, 76, 255, 0.3);
    }

    /* ─── Job Card ─── */
    .job-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      box-shadow: var(--shadow-card);
      transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
      position: relative;
    }

    .job-card::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: var(--radius-lg);
      background: linear-gradient(135deg, rgba(91, 76, 255, 0.04) 0%, transparent 50%);
      opacity: 0;
      transition: opacity 0.3s ease;
      pointer-events: none;
    }

    .job-card:hover {
      transform: translateY(-6px);
      border-color: rgba(91, 76, 255, 0.2);
      box-shadow: var(--shadow-hover);
    }

    .job-card:hover::before {
      opacity: 1;
    }

    /* Card image */
    .card-img-wrap {
      position: relative;
      height: 220px;
      overflow: hidden;
      background: var(--surface-mid);
    }

    .card-img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .job-card:hover .card-img-wrap img {
      transform: scale(1.06);
    }

    /* Price badge */
    .price-badge {
      position: absolute;
      top: 14px;
      right: 14px;
      background: rgba(10, 10, 15, 0.88);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: #fff;
      font-family: 'Syne', sans-serif;
      font-size: 13px;
      font-weight: 700;
      padding: 6px 14px;
      border-radius: 100px;
      letter-spacing: 0.01em;
    }

    /* Verified badge */
    .verified-badge {
      position: absolute;
      bottom: 14px;
      left: 14px;
      background: var(--green);
      color: #fff;
      font-size: 9.5px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 6px;
    }

    /* Card body */
    .card-body {
      padding: 22px 24px;
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .card-type {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink-faint);
    }

    .card-title {
      font-family: 'Syne', sans-serif;
      font-size: 1.05rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: var(--ink);
      margin-top: 4px;
      line-height: 1.3;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .card-location {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 12px;
      color: var(--ink-faint);
      margin-top: 4px;
    }

    .card-desc {
      font-size: 13px;
      color: var(--ink-muted);
      line-height: 1.6;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin-top: 12px;
      flex: 1;
    }

    /* Card footer */
    .card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 14px;
      margin-top: 16px;
      border-top: 1px solid var(--surface-mid);
    }

    .rating-chip {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 12px;
      font-weight: 600;
      color: var(--ink);
    }

    .helper-chip {
      font-size: 11.5px;
      font-weight: 500;
      color: var(--ink-faint);
      background: var(--surface-off);
      padding: 4px 10px;
      border-radius: 100px;
    }

    /* CTA area */
    .card-cta {
      padding: 0 24px 20px;
      margin-top: 0;
    }

    .cta-apply {
      display: block;
      width: 100%;
      text-align: center;
      font-family: 'Syne', sans-serif;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 13px 20px;
      border-radius: var(--radius-sm);
      text-decoration: none;
      transition: all 0.2s ease;
      background: var(--accent-tint);
      color: var(--accent);
      border: 1px solid rgba(91, 76, 255, 0.18);
    }

    .cta-apply:hover {
      background: var(--accent);
      color: #fff;
      box-shadow: 0 8px 20px rgba(91, 76, 255, 0.3);
    }

    .cta-edit {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      font-family: 'Syne', sans-serif;
      font-size: 11.5px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 12px;
      border-radius: var(--radius-sm);
      background: var(--ink);
      color: #fff;
      transition: all 0.2s ease;
    }

    .cta-edit:hover {
      background: #1a1a2e;
    }

    .cta-delete {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      font-family: 'Syne', sans-serif;
      font-size: 11.5px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 12px;
      border-radius: var(--radius-sm);
      background: #fff5f5;
      color: #d73a3a;
      border: 1px solid #ffd0d0;
      transition: all 0.2s ease;
      cursor: pointer;
      width: 100%;
    }

    .cta-delete:hover {
      background: #fee2e2;
    }

    /* ─── Empty state ─── */
    .empty-state {
      background: var(--surface);
      border: 1px dashed var(--border);
      border-radius: var(--radius-xl);
      padding: 80px 40px;
      text-align: center;
      max-width: 480px;
      margin: 0 auto;
    }

    .empty-icon {
      width: 64px;
      height: 64px;
      border-radius: 20px;
      background: var(--surface-off);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 26px;
      margin: 0 auto 20px;
    }

    /* ─── Fade-in animation ─── */
    .fade-up {
      opacity: 0;
      transform: translateY(24px);
      animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes fadeUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Stagger delays */
    .d-0 {
      animation-delay: 0s;
    }

    .d-1 {
      animation-delay: 0.1s;
    }

    .d-2 {
      animation-delay: 0.18s;
    }

    .d-3 {
      animation-delay: 0.26s;
    }

    .d-4 {
      animation-delay: 0.34s;
    }

    /* ─── Scrollbar ─── */
    ::-webkit-scrollbar {
      width: 5px;
    }

    ::-webkit-scrollbar-track {
      background: transparent;
    }

    ::-webkit-scrollbar-thumb {
      background: var(--surface-mid);
      border-radius: 10px;
    }
  </style>

  </head>

  <body>
    <!-- Background atmosphere -->
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="orb orb-1" aria-hidden="true"></div>
    <div class="orb orb-2" aria-hidden="true"></div>

    <!-- NAVBAR HEADER -->
    <%- include('../partials/header', { isLoggedIn: isLoggedIn, user: user }) %>

      <main style="position:relative; z-index:1; padding-top: 120px; padding-bottom: 100px;">
        <div class="page-wrap">

          <!-- ── HERO ── -->
          <section style="max-width: 860px; margin-bottom: 80px;" class="fade-up d-0">

            <div class="eyebrow">
              <span class="eyebrow-dot"></span>
              Verified campus gigs — live now
            </div>

            <h1 class="hero-h1" style="margin-top: 22px;">
              Empowering students<br>
              with <mark>micro‑jobs.</mark>
            </h1>

            <p
              style="margin-top: 20px; font-size: 1.1rem; line-height: 1.7; color: var(--ink-muted); max-width: 540px;">
              Discover tasks, build professional skills, and earn rewards —
              all hosted right inside your university campus.
            </p>

            <div style="display:flex; flex-wrap:wrap; gap: 12px; margin-top: 32px; align-items:center;">
              <a href="/homes" class="btn-primary">
                Explore all gigs
                <span class="arrow-icon"><i class="fa-solid fa-arrow-right"></i></span>
              </a>
              <a href="/smart-matches" class="btn-ghost">
                🎯 &nbsp;Get AI matches
              </a>
            </div>

          </section>

          <!-- ── STATS STRIP ── -->
          <section style="display:grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-bottom: 80px;"
            class="fade-up d-1">

            <div class="stat-card">
              <div class="stat-val" style="color:var(--ink);">100+</div>
              <div class="stat-label">Active jobs</div>
            </div>
            <div class="stat-card">
              <div class="stat-val" style="color:var(--green);">₹10k+</div>
              <div class="stat-label">Earned by students</div>
            </div>
            <div class="stat-card">
              <div class="stat-val" style="color:var(--accent);">4.9★</div>
              <div class="stat-label">Avg trust score</div>
            </div>
            <div class="stat-card">
              <div class="stat-val" style="color:var(--ink);">100%</div>
              <div class="stat-label">Verified postings</div>
            </div>

          </section>

          <!-- ── FILTER BAR ── -->
          <div
            style="display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:20px; margin-bottom: 36px;"
            class="fade-up d-2">

            <div style="display:flex; align-items:center; gap: 10px;">
              <span class="section-rule"></span>
              <h2 class="font-display" style="font-size: 1.5rem; font-weight: 800; letter-spacing:-0.025em; margin:0;">
                Live postings
              </h2>
            </div>

            <div style="display:flex; flex-wrap:wrap; gap: 8px;">
              <button class="pill-filter active" onclick="setFilter(this)">All</button>
              <button class="pill-filter" onclick="setFilter(this)">Delivery</button>
              <button class="pill-filter" onclick="setFilter(this)">Tutoring</button>
              <button class="pill-filter" onclick="setFilter(this)">Tech Support</button>
              <button class="pill-filter" onclick="setFilter(this)">Errands</button>
            </div>

          </div>

          <!-- ── LISTINGS GRID ── -->
          <% if (registeredHomes.length===0) { %>

            <div class="empty-state fade-up d-3">
              <div class="empty-icon">🔍</div>
              <h3 class="font-display" style="font-size:1.2rem; font-weight:800; margin:0 0 8px;">
                No postings live right now
              </h3>
              <p style="font-size:13.5px; color:var(--ink-muted); line-height:1.7; margin:0;">
                Be the first on campus to post an opportunity, or check back shortly!
              </p>
            </div>

            <% } else { %>

              <ul
                style="display:grid; grid-template-columns:repeat(3,1fr); gap: 28px; list-style:none; margin:0; padding:0;"
                class="fade-up d-3">
                <% registeredHomes.forEach(home=> { %>

                  <li class="job-card">

                    <!-- Image -->
                    <div class="card-img-wrap">
                      <img src="<%= home.photo %>" alt="<%= home.houseName %>">
                      <span class="price-badge">₹ <%= home.price %></span>
                      <span class="verified-badge">✓ Verified</span>
                    </div>

                    <!-- Body -->
                    <div class="card-body">
                      <span class="card-type">
                        <%= home.propertytype %>
                      </span>
                      <h3 class="card-title">
                        <%= home.houseName %>
                      </h3>
                      <span class="card-location">
                        <i class="fa-solid fa-location-dot" style="font-size:10px; color:var(--ink-faint);"></i>
                        <%= home.location %>
                      </span>
                      <p class="card-desc">
                        <%= home.description %>
                      </p>

                      <!-- Footer -->
                      <div class="card-footer">
                        <div class="rating-chip">
                          <i class="fa-solid fa-star" style="color:#f5a623; font-size:12px;"></i>
                          <%= home.rating %> trust score
                        </div>
                        <span class="helper-chip">
                          <%= home.maxguest %> helper<%= home.maxguest> 1 ? 's' : '' %> needed
                        </span>
                      </div>
                    </div>

                    <!-- CTA -->
                    <div class="card-cta">
                      <% if (isLoggedIn && user && home.owner && home.owner.toString()===user._id.toString()) { %>
                        <div style="display:flex; gap: 8px;">
                          <a href="/edithome/<%= home._id %>?editing=true" class="cta-edit">
                            <i class="fa-solid fa-pen" style="font-size:10px;"></i> Edit
                          </a>
                          <form action="/delete-home/<%= home._id %>" method="POST" style="flex:1;">
                            <button type="submit" class="cta-delete">
                              <i class="fa-solid fa-trash" style="font-size:10px;"></i> Delete
                            </button>
                          </form>
                        </div>
                        <% } else { %>
                          <a href="<%= isLoggedIn ? '/homes/' + home._id : '/login' %>" class="cta-apply">
                            View &amp; Apply →
                          </a>
                          <% } %>
                    </div>

                  </li>

                  <% }) %>
              </ul>

              <% } %>

        </div><!-- /.page-wrap -->
      </main>

      <script>
        function setFilter(el) {
          document.querySelectorAll('.pill-filter').forEach(p => p.classList.remove('active'));
          el.classList.add('active');
        }

        // Staggered card entrance
        document.querySelectorAll('.job-card').forEach((card, i) => {
          card.style.opacity = '0';
          card.style.transform = 'translateY(28px)';
          card.style.transition = 'opacity 0.55s ease, transform 0.55s cubic-bezier(0.16,1,0.3,1)';
          setTimeout(() => {
            card.style.opacity = '1';
            card.style.transform = 'translateY(0)';
          }, 420 + i * 80);
        });
      </script>

      <%- include('../partials/chatbot-widget') %>

  </body>

  </html>