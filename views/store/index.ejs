<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<link rel="stylesheet" href="/css/output.css" />

<%- include('../partials/head', { pageTitle: 'Campus Job Portal' }) %>

<style>
  :root {
    --brand-primary: #6366f1; /* Indigo */
    --brand-emerald: #10b981; /* Emerald */
    --brand-slate: #0f172a; /* Slate 900 */
    --bg-light: #f8fafc; /* Slate 50 */
    --border-soft: #f1f5f9; /* Slate 100 */
    --card-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.04), 0 1px 1px rgba(0, 0, 0, 0.01);
  }

  body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    background: var(--bg-light);
    color: #334155;
  }

  .font-heading { font-family: 'Outfit', sans-serif; }

  /* Premium Premium Gradient Text */
  .gradient-text {
    background: linear-gradient(135deg, #4f46e5 0%, #10b981 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Neo-Glassmorphism Cards */
  .premium-card {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(226, 232, 240, 0.8);
    border-radius: 24px;
    box-shadow: var(--card-shadow);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .premium-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -15px rgba(99, 102, 241, 0.12);
    border-color: rgba(99, 102, 241, 0.3);
  }

  /* Glow effects */
  .glow-btn {
    position: relative;
    background: var(--brand-slate);
    color: white;
    font-weight: 600;
    transition: all 0.25s ease;
  }
  .glow-btn:hover {
    background: #1e293b;
    box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.4);
    transform: translateY(-1px);
  }

  /* Filtering Pills */
  .pill-filter {
    cursor: pointer;
    font-size: 0.82rem;
    font-weight: 600;
    padding: 8px 20px;
    border-radius: 100px;
    border: 1px solid #e2e8f0;
    background: white;
    color: #64748b;
    transition: all 0.2s ease;
  }
  .pill-filter:hover {
    border-color: var(--brand-primary);
    color: var(--brand-primary);
  }
  .pill-filter.active {
    background: var(--brand-primary);
    color: white;
    border-color: var(--brand-primary);
    box-shadow: 0 8px 20px -6px rgba(99, 102, 241, 0.4);
  }

  /* Fade-ups */
  .fade-in-up {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }
</style>

</head>

<body class="min-h-screen selection:bg-indigo-100 selection:text-indigo-900">

  <!-- NAVBAR HEADER -->
  <%- include('../partials/header', { isLoggedIn: isLoggedIn, user: user }) %>

  <!-- MAIN COVER -->
  <main class="max-w-7xl mx-auto px-6 sm:px-8 pt-32 pb-24">

    <!-- HERO SECTION -->
    <section class="max-w-4xl mb-16 fade-in-up">
      <div class="inline-flex items-center gap-2 bg-indigo-50 border border-indigo-100 text-indigo-700 px-4 py-1.5 rounded-full text-xs font-semibold shadow-sm mb-6">
        <span class="w-2 h-2 rounded-full bg-indigo-600 animate-pulse"></span>
        Verified Campus Gigs Active
      </div>

      <h1 class="font-heading text-5xl sm:text-7xl font-extrabold text-slate-900 leading-[1.1] tracking-tight">
        Empowering students with <span class="gradient-text">micro-jobs.</span>
      </h1>
      
      <p class="mt-6 text-lg sm:text-xl text-slate-500 max-w-2xl leading-relaxed">
        Discover tasks, build professional skills, and earn rewards — all hosted right inside your university campus.
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/homes" class="glow-btn px-8 py-3.5 rounded-2xl flex items-center gap-2 text-sm uppercase tracking-wider font-heading">
          Explore All Gigs <i class="fa-solid fa-arrow-right text-xs"></i>
        </a>
        <a href="/smart-matches" class="px-8 py-3.5 rounded-2xl border border-slate-200 bg-white text-slate-600 hover:border-slate-300 transition text-sm font-semibold flex items-center gap-2">
          🎯 Get AI Matches
        </a>
      </div>
    </section>

    <!-- STATS STRIP -->
    <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-20 fade-in-up" style="animation-delay: 0.15s;">
      <div class="premium-card p-6 text-center">
        <h3 class="font-heading text-3xl font-extrabold text-slate-900">100+</h3>
        <p class="text-xs text-slate-400 font-semibold uppercase mt-1 tracking-wider">Total Active Jobs</p>
      </div>
      <div class="premium-card p-6 text-center">
        <h3 class="font-heading text-3xl font-extrabold text-emerald-600">10+</h3>
        <p class="text-xs text-slate-400 font-semibold uppercase mt-1 tracking-wider">Earned by Students</p>
      </div>
      <div class="premium-card p-6 text-center">
        <h3 class="font-heading text-3xl font-extrabold text-indigo-600">4.9★</h3>
        <p class="text-xs text-slate-400 font-semibold uppercase mt-1 tracking-wider">Avg Trust Score</p>
      </div>
      <div class="premium-card p-6 text-center">
        <h3 class="font-heading text-3xl font-extrabold text-slate-900">100%</h3>
        <p class="text-xs text-slate-400 font-semibold uppercase mt-1 tracking-wider">Verified Postings</p>
      </div>
    </section>

    <!-- FILTER SECTION -->
    <div class="flex flex-wrap items-center justify-between gap-6 mb-10 fade-in-up" style="animation-delay: 0.25s;">
      <div class="flex items-center gap-2">
        <span class="w-1 h-6 bg-indigo-600 rounded-full"></span>
        <h2 class="font-heading text-2xl font-bold text-slate-900">Live Postings</h2>
      </div>

      <div class="flex flex-wrap gap-2">
        <button class="pill-filter active" onclick="setFilter(this)">All</button>
        <button class="pill-filter" onclick="setFilter(this)">Delivery</button>
        <button class="pill-filter" onclick="setFilter(this)">Tutoring</button>
        <button class="pill-filter" onclick="setFilter(this)">Tech Support</button>
        <button class="pill-filter" onclick="setFilter(this)">Errands</button>
      </div>
    </div>

    <!-- LISTINGS GRID -->
    <% if (registeredHomes.length === 0) { %>
      <div class="premium-card p-16 text-center max-w-lg mx-auto fade-in-up" style="animation-delay: 0.3s;">
        <div class="w-16 h-16 bg-slate-50 border border-slate-100 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
          🔍
        </div>
        <h3 class="font-heading text-xl font-bold text-slate-900">No postings live right now</h3>
        <p class="text-sm text-slate-500 mt-2 leading-relaxed">Be the first on campus to post an opportunity or check back shortly!</p>
      </div>

    <% } else { %>
      <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 fade-in-up" style="animation-delay: 0.35s;">
        <% registeredHomes.forEach(home => { %>
          <li class="premium-card overflow-hidden flex flex-col group">

            <!-- Banner image wrap -->
            <div class="relative h-56 overflow-hidden bg-slate-100">
              <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
              <span class="absolute top-4 right-4 bg-slate-900/80 backdrop-blur-md border border-white/10 text-white font-heading text-xs font-bold px-3 py-1.5 rounded-full">
                ₹ <%= home.price %>
              </span>
              <span class="absolute bottom-4 left-4 bg-emerald-500 text-white text-[9px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-md">
                Verified
              </span>
            </div>

            <!-- Content Area -->
            <div class="p-6 flex flex-col flex-grow">
              <div class="mb-4">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block"><%= home.propertytype %></span>
                <h3 class="font-heading text-lg font-bold text-slate-900 mt-1 leading-snug truncate">
                  <%= home.houseName %>
                </h3>
                <p class="text-xs text-slate-400 mt-1 flex items-center gap-1">
                  <i class="fa-solid fa-map-pin text-slate-300"></i> <%= home.location %>
                </p>
              </div>

              <p class="text-xs text-slate-500 leading-relaxed line-clamp-2 mb-6">
                <%= home.description %>
              </p>

              <!-- Footer info -->
              <div class="mt-auto pt-4 border-t border-slate-100 flex items-center justify-between">
                <div class="flex items-center gap-1 text-xs font-bold text-slate-600">
                  <i class="fa-solid fa-star text-amber-400"></i> <%= home.rating %> trust score
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-xs font-semibold text-slate-500">Need: <%= home.maxguest %> helper<%= home.maxguest > 1 ? 's' : '' %></span>
                </div>
              </div>

              <!-- CTA Apply -->
              <a href="/homes/<%= home._id %>" class="mt-4 w-full bg-slate-50 hover:bg-indigo-50 border border-slate-100 hover:border-indigo-200 text-slate-700 hover:text-indigo-700 text-center font-heading text-xs font-bold uppercase tracking-wider py-3 rounded-xl transition">
                View &amp; Apply
              </a>
            </div>

          </li>
        <% }) %>
      </ul>
    <% } %>

  </main>

  <script>
    function setFilter(el) {
      document.querySelectorAll('.pill-filter').forEach(p => p.classList.remove('active'));
      el.classList.add('active');
    }
  </script>

  <%- include('../partials/chatbot-widget') %>

</body>
</html>
