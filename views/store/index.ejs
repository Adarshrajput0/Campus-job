<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/output.css" />

<%- include('../partials/head') %>

<style>
  :root {
    --ink: #0d0d0d;
    --cream: #f5f0e8;
    --lime: #c8f04a;
    --lime-dark: #a8cc30;
    --muted: #6b6b6b;
    --card-bg: #ffffff;
    --border: #e4e0d8;
  }

  * { box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--ink);
  }

  .font-display { font-family: 'Syne', sans-serif; }
  .font-heading { font-family: 'Clash Display', sans-serif; }

  /* TICKER */
  .ticker-wrap {
    overflow: hidden;
    background: var(--ink);
    color: var(--lime);
    white-space: nowrap;
  }
  .ticker-inner {
    display: inline-block;
    animation: ticker 28s linear infinite;
    font-family: 'Syne', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    font-weight: 600;
    text-transform: uppercase;
  }
  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* HERO */
  .hero-label {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--lime);
    color: var(--ink);
    font-family: 'Syne', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
  }

  .hero-label .dot {
    width: 6px; height: 6px;
    background: var(--ink);
    border-radius: 50%;
    animation: pulse-dot 1.6s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.5); opacity: 0.6; }
  }

  h1.hero-title {
    font-family: 'Clash Display', sans-serif;
    font-size: clamp(2.8rem, 7vw, 6rem);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.03em;
  }

  h1.hero-title em {
    font-style: normal;
    color: transparent;
    -webkit-text-stroke: 2px var(--ink);
  }

  /* STATS */
  .stat-card {
    border: 1.5px solid var(--border);
    border-radius: 18px;
    padding: 20px 28px;
    background: white;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .stat-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }

  /* FILTER PILLS */
  .filter-pill {
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    padding: 8px 18px;
    border-radius: 100px;
    border: 1.5px solid var(--border);
    background: white;
    color: var(--muted);
    transition: all 0.18s ease;
    user-select: none;
  }
  .filter-pill:hover {
    border-color: var(--ink);
    color: var(--ink);
    background: var(--cream);
  }
  .filter-pill.active {
    background: var(--ink);
    color: var(--lime);
    border-color: var(--ink);
  }

  /* JOB CARD */
  .job-card {
    background: white;
    border: 1.5px solid var(--border);
    border-radius: 24px;
    overflow: hidden;
    transition: transform 0.28s cubic-bezier(.22,.68,0,1.2), box-shadow 0.28s ease;
    display: flex;
    flex-direction: column;
  }
  .job-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 48px rgba(0,0,0,0.10);
    border-color: #c5c0b8;
  }

  .job-card__img-wrap {
    position: relative;
    overflow: hidden;
    height: 200px;
  }
  .job-card__img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .job-card:hover .job-card__img-wrap img {
    transform: scale(1.06);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: 'Syne', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 100px;
  }

  .badge-open   { background: var(--lime); color: var(--ink); }
  .badge-urgent { background: var(--ink);  color: var(--lime); }
  .badge-price  { background: rgba(0,0,0,0.65); color: white; backdrop-filter: blur(6px); }

  .save-btn {
    background: rgba(255,255,255,0.9);
    border: none;
    border-radius: 100px;
    padding: 6px 12px;
    font-size: 0.72rem;
    font-weight: 600;
    cursor: pointer;
    backdrop-filter: blur(6px);
    transition: background 0.15s;
  }
  .save-btn:hover { background: white; }

  .job-card__body {
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .job-title {
    font-family: 'Clash Display', sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .job-location {
    font-size: 0.82rem;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .tag {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 8px;
  }
  .tag-type { background: #eef2ff; color: #4338ca; }
  .tag-need { background: #f0fdf4; color: #166534; }

  .job-desc {
    font-size: 0.84rem;
    color: #555;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .job-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 8px;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  .rating {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .posted-time {
    font-size: 0.72rem;
    color: #aaa;
  }

  .apply-btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 12px;
    border-radius: 14px;
    background: var(--ink);
    color: var(--lime);
    font-family: 'Syne', sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.18s, transform 0.15s;
  }
  .apply-btn:hover {
    background: #222;
    transform: scale(1.01);
  }

  /* EMPTY STATE */
  .empty-state {
    border: 2px dashed var(--border);
    border-radius: 28px;
    padding: 64px 40px;
    text-align: center;
    margin: 48px auto;
    max-width: 480px;
  }

  /* SECTION DIVIDER */
  .section-label {
    font-family: 'Syne', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* PAGE FADE-IN */
  .fade-up {
    animation: fadeUp 0.6s ease both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.2s; }
  .delay-3 { animation-delay: 0.3s; }
  .delay-4 { animation-delay: 0.4s; }

  /* Stagger job cards */
  .job-card { opacity: 0; animation: fadeUp 0.5s ease forwards; }
  .job-card:nth-child(1) { animation-delay: 0.15s; }
  .job-card:nth-child(2) { animation-delay: 0.25s; }
  .job-card:nth-child(3) { animation-delay: 0.35s; }
  .job-card:nth-child(4) { animation-delay: 0.45s; }
  .job-card:nth-child(5) { animation-delay: 0.55s; }
  .job-card:nth-child(6) { animation-delay: 0.65s; }
</style>

</head>

<body class="min-h-screen">

<%- include('../partials/header', { isLoggedIn: isLoggedIn, user: user }) %>

<!-- TICKER BAR -->
<div class="ticker-wrap py-2.5">
  <span class="ticker-inner">
    ✦ Campus Micro Jobs &nbsp;&nbsp;&nbsp; ✦ Earn While You Study &nbsp;&nbsp;&nbsp; ✦ Flexible Hours &nbsp;&nbsp;&nbsp; ✦ Verified Postings &nbsp;&nbsp;&nbsp; ✦ Instant Apply &nbsp;&nbsp;&nbsp; ✦ Campus Micro Jobs &nbsp;&nbsp;&nbsp; ✦ Earn While You Study &nbsp;&nbsp;&nbsp; ✦ Flexible Hours &nbsp;&nbsp;&nbsp; ✦ Verified Postings &nbsp;&nbsp;&nbsp; ✦ Instant Apply &nbsp;&nbsp;&nbsp;
  </span>
</div>

<main class="max-w-7xl mx-auto px-5 sm:px-8 pb-28">

  <!-- HERO -->
  <section class="pt-16 pb-12 max-w-4xl">
    <div class="fade-up">
      <span class="hero-label">
        <span class="dot"></span>
        Live Opportunities
      </span>
    </div>

    <h1 class="hero-title mt-5 fade-up delay-1">
      Find Campus<br><em>Micro Jobs</em>
    </h1>

    <p class="mt-5 text-base text-gray-500 max-w-xl leading-relaxed fade-up delay-2">
      Discover tasks, freelance gigs, and part-time work — posted by students and staff right on your campus.
    </p>
  </section>

  <!-- STATS STRIP -->
  <div class="grid grid-cols-3 gap-4 max-w-xl fade-up delay-3">
    <div class="stat-card">
      <p class="font-heading text-2xl font-bold text-gray-900">100+</p>
      <p class="section-label mt-1">Jobs Posted</p>
    </div>
    <div class="stat-card">
      <p class="font-heading text-2xl font-bold text-gray-900">50+</p>
      <p class="section-label mt-1">Earning Now</p>
    </div>
    <div class="stat-card">
      <p class="font-heading text-2xl font-bold text-gray-900">4.8★</p>
      <p class="section-label mt-1">Avg Rating</p>
    </div>
  </div>

  <!-- FILTER ROW -->
  <div class="mt-12 flex flex-wrap items-center gap-3 fade-up delay-4">
    <span class="section-label mr-2">Browse:</span>
    <button class="filter-pill active" onclick="setFilter(this)">All Jobs</button>
    <button class="filter-pill" onclick="setFilter(this)">Delivery</button>
    <button class="filter-pill" onclick="setFilter(this)">Tech</button>
    <button class="filter-pill" onclick="setFilter(this)">Event</button>
    <button class="filter-pill" onclick="setFilter(this)">Cleaning</button>
  </div>

  <!-- DIVIDER -->
  <div class="mt-10 mb-8 flex items-center gap-4">
    <div class="flex-1 h-px bg-[var(--border)]"></div>
    <span class="section-label">Available Listings</span>
    <div class="flex-1 h-px bg-[var(--border)]"></div>
  </div>

  <!-- EMPTY STATE -->
  <% if (registeredHomes.length === 0) { %>
  <div class="empty-state fade-up">
    <div class="text-4xl mb-4">🔍</div>
    <h2 class="font-heading text-2xl font-semibold text-gray-800">No jobs posted yet</h2>
    <p class="text-gray-500 mt-2 text-sm">Check back soon — or be the first to post a task.</p>
    <a href="/post" class="apply-btn mt-8 inline-block w-auto px-8">Post a Task →</a>
  </div>

  <% } else { %>

  <!-- JOB GRID -->
  <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% registeredHomes.forEach(home => { %>

    <li class="job-card">

      <!-- IMAGE AREA -->
      <div class="job-card__img-wrap">
        <img src="<%= home.photo %>" alt="<%= home.houseName %>">

        <!-- PRICE -->
        <span class="badge badge-price absolute top-4 right-4">₹ <%= home.price %></span>

        <!-- STATUS BADGES -->
        <div class="absolute bottom-4 left-4 flex gap-2">
          <span class="badge badge-open">● Open</span>
          <span class="badge badge-urgent">Urgent</span>
        </div>

        <!-- SAVE -->
        <button class="save-btn absolute top-4 left-4">♡ Save</button>
      </div>

      <!-- BODY -->
      <div class="job-card__body">

        <div>
          <h3 class="job-title"><%= home.houseName %></h3>
          <p class="job-location mt-1">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
            <%= home.location %>
          </p>
        </div>

        <!-- TAGS -->
        <div class="flex gap-2 flex-wrap">
          <span class="tag tag-type"><%= home.propertytype %></span>
          <span class="tag tag-need">Needed: <%= home.maxguest %></span>
        </div>

        <!-- DESCRIPTION -->
        <p class="job-desc"><%= home.description %></p>

        <!-- META -->
        <div class="job-meta">
          <span class="rating">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
            <%= home.rating %>
          </span>
          <span class="posted-time">Posted recently</span>
        </div>

        <!-- CTA -->
        <a href="/homes/<%= home._id %>" class="apply-btn">View & Apply →</a>

      </div>
    </li>

    <% }) %>
  </ul>

  <% } %>

  <!-- FOOTER TEXT -->
  <p class="mt-20 text-sm text-gray-400 text-center font-display tracking-wide">
    Explore flexible campus jobs — earn money and build skills while studying.
  </p>

</main>

<script>
  function setFilter(el) {
    document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
    el.classList.add('active');
  }
</script>

</body>
</html>
