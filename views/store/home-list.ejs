
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/output.css" />

  <%- include('../partials/head') %>
  </head>

  <body
    class="min-h-screen bg-gradient-to-b from-[#fff1f2] via-white to-[#f7f7f7] font-sans"
  >

  
   <%- include('../partials/header', { 
      isLoggedIn: isLoggedIn, 
      user: user 
}) %>

<main
  class="min-h-screen flex flex-col items-center pt-28 text-center 
         bg-gradient-to-b from-green-50 via-white to-gray-50"
>

 
  <div class="max-w-4xl px-4">
    <h1
      class="text-5xl md:text-6xl font-extrabold text-green-700 tracking-tight"
    >
      Find campus tasks near you 🚀
    </h1>

    <p class="mt-4 text-lg text-gray-600">
      Explore micro-jobs posted by students. Earn, help, and grow together.
    </p>
  </div>

  <!-- LISTINGS -->
  <ul class="mt-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-12 px-6 max-w-7xl">

    <% registeredHomes.forEach(home => { %>

    <li class="group relative rounded-3xl overflow-hidden
               bg-white/80 backdrop-blur-xl
               border border-white/50 shadow-xl
               hover:shadow-2xl transition-all duration-500 hover:-translate-y-3">

      <!-- Glow -->
      <div class="absolute inset-0 rounded-3xl opacity-0 group-hover:opacity-100 transition
                  bg-gradient-to-br from-green-200/20 via-emerald-200/20 to-teal-200/20"></div>

      <!-- Image -->
      <div class="relative overflow-hidden">
        <img
          src="<%= home.photo %>"
          alt="<%= home.houseName %>"
          class="w-full h-60 object-cover transition-transform duration-700 group-hover:scale-110"
        />

        <!-- Payment Badge -->
        <span
          class="absolute top-4 right-4 bg-black/70 text-white px-4 py-1 rounded-full text-sm font-semibold backdrop-blur-md"
        >
          ₹ <%= home.price %> reward
        </span>

        <!-- Verified -->
        <span
          class="absolute top-4 left-4 bg-white/80 text-xs font-bold px-3 py-1 rounded-full shadow"
        >
          ✔ Verified Task
        </span>
      </div>

      <!-- Content -->
      <div class="relative p-6 space-y-3 text-left">

        <!-- Task Title -->
        <h3
          class="text-2xl font-bold text-gray-900 group-hover:text-green-600 transition"
        >
          <%= home.houseName %>
        </h3>

        <!-- Location -->
        <p class="text-gray-600">📍 <%= home.location %></p>

        <!-- Task Type + People Needed -->
        <div class="flex items-center justify-between text-sm text-gray-600 pt-1">
          <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full font-semibold">
            🛠 <%= home.propertytype %>
          </span>

          <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full font-semibold">
            👥 Needed: <%= home.maxguest %>
          </span>
        </div>

        <!-- Description -->
        <p class="text-gray-600 text-sm leading-relaxed line-clamp-2">
          <%= home.description %>
        </p>

        <!-- Bottom -->
        <div class="flex items-center justify-between pt-3">

          <!-- Rating → Trust -->
          <span class="flex items-center gap-1 text-yellow-500 font-semibold">
            ⭐ <%= home.rating %> trust
          </span>

          <!-- View -->
          <a
            href="/homes/<%= home._id %>"
            class="px-5 py-2 rounded-full bg-green-600 text-white text-sm font-semibold
                   shadow hover:bg-green-700 hover:shadow-lg active:scale-95 transition"
          >
            View Task
          </a>
        </div>

        <!-- Save Button -->
        <div class="pt-3">
          <%- include('../partials/favourite',{home:home}) %>
        </div>

      </div>

    </li>

    <% }) %>
  </ul>

  <!-- FOOTER -->
  <p class="mt-20 text-lg md:text-xl text-gray-600 max-w-xl leading-relaxed">
    💼 Small tasks. Real earnings. Stronger campus community.
  </p>

</main>

   
  </body>
</html>
