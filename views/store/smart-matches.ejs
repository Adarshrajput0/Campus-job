<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<link rel="stylesheet" href="/css/output.css" />

<%- include('../partials/head') %>

<style>
  :root {
    --brand-primary: #6366f1; /* Indigo */
    --brand-emerald: #10b981; /* Emerald */
    --brand-slate: #0f172a; /* Slate 900 */
    --bg-light: #f8fafc; /* Slate 50 */
    --border-soft: #f1f5f9; /* Slate 100 */
    --card-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.04), 0 1px 1px rgba(0, 0, 0, 0.01);
  }

  body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    background: var(--bg-light);
    color: #334155;
  }

  .font-heading { font-family: 'Outfit', sans-serif; }

  /* Job Card style */
  .match-card {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(226, 232, 240, 0.8);
    border-radius: 26px;
    overflow: hidden;
    box-shadow: var(--card-shadow);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    opacity: 0;
    animation: fadeUp 0.5s ease forwards;
  }
  .match-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px -15px rgba(99, 102, 241, 0.12);
    border-color: rgba(99, 102, 241, 0.3);
  }

  .match-card__img-wrap {
    position: relative;
    overflow: hidden;
    height: 180px;
    background-color: #f1f5f9;
  }
  .match-card__img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .match-card:hover .match-card__img-wrap img {
    transform: scale(1.04);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: 'Outfit', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 100px;
  }

  .match-card__body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .job-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--brand-slate);
    letter-spacing: -0.01em;
    line-height: 1.25;
  }

  .job-desc {
    font-size: 0.82rem;
    color: #64748b;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Match Insight Banner style */
  .insight-banner {
    border-radius: 16px;
    padding: 14px 16px;
    font-size: 0.8rem;
    line-height: 1.5;
    border: 1px solid transparent;
  }
  .insight-banner-ai {
    background: #f0fdf4;
    border-color: #dcfce7;
    color: #166534;
  }
  .insight-banner-local {
    background: #fffbeb;
    border-color: #fef08a;
    color: #92400e;
  }

  .apply-btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 12px;
    border-radius: 14px;
    background: var(--brand-slate);
    color: white;
    font-family: 'Outfit', sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.2s;
    margin-top: auto;
  }
  .apply-btn:hover {
    background: #1e293b;
    box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.3);
    transform: translateY(-1px);
  }

  /* Fade ups */
  .fade-up {
    animation: fadeUp 0.6s ease both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Stagger cards */
  .match-card:nth-child(1) { animation-delay: 0.1s; }
  .match-card:nth-child(2) { animation-delay: 0.2s; }
  .match-card:nth-child(3) { animation-delay: 0.3s; }
  .match-card:nth-child(4) { animation-delay: 0.4s; }

  .engine-chip {
    font-family: 'Outfit', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .engine-chip .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
  }

  .section-label {
    font-family: 'Outfit', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #94a3b8;
  }
</style>

</head>

<body class="min-h-screen">

<%- include('../partials/header', { isLoggedIn: isLoggedIn, user: user }) %>

<main class="max-w-7xl mx-auto px-5 sm:px-8 pt-32 pb-28">

  <!-- PAGE HEADER -->
  <section class="mb-12 flex flex-col md:flex-row md:items-end md:justify-between gap-6">
    <div class="fade-up">
      <div class="inline-flex items-center gap-2 bg-indigo-50 border border-indigo-100 text-indigo-700 px-4 py-1.5 rounded-full text-xs font-semibold shadow-sm animate-pulse">
        🎯 Smart Matches Recommendation Engine
      </div>
      <h1 class="font-heading text-4xl sm:text-5xl font-extrabold mt-4 tracking-tight text-slate-900">
        AI Smart Matches
      </h1>
      <p class="mt-2 text-slate-500 max-w-xl text-sm sm:text-base leading-relaxed">
        Personalized micro-job recommendations matched directly to your student bio & skill set. Keep your skills updated to discover new opportunities.
      </p>
    </div>

    <!-- ENGINE BADGE -->
    <% if (!profileIncomplete && matches.length > 0) { %>
      <div class="fade-up md:mb-2">
        <% if (aiUsed) { %>
          <div class="engine-chip text-emerald-800 border border-emerald-200 bg-emerald-50">
            <span class="dot bg-emerald-500 animate-ping"></span>
            🤖 OpenAI GPT Engine Active
          </div>
        <% } else { %>
          <div class="engine-chip text-amber-800 border border-amber-200 bg-amber-50">
            <span class="dot bg-amber-500 animate-pulse"></span>
            ⚡ Local NLP Engine Active
          </div>
        <% } %>
      </div>
    <% } %>
  </section>

  <!-- EMPTY STATE: PROFILE INCOMPLETE -->
  <% if (profileIncomplete) { %>
    <div class="max-w-md mx-auto text-center border-2 border-dashed border-slate-200 rounded-[28px] p-8 sm:p-12 fade-up">
      <div class="text-5xl mb-4">👤</div>
      <h2 class="font-heading text-2xl font-bold text-slate-800">Set up your profile</h2>
      <p class="text-sm text-slate-500 mt-3 leading-relaxed">
        We need to know your bio and skills (like Stationery, Printing, Errands, or Tutoring) before calculating matches!
      </p>
      <a href="/profile" class="apply-btn mt-8 inline-block w-auto px-8">Complete Profile →</a>
    </div>

  <!-- EMPTY STATE: NO MATCHES FOUND -->
  <% } else if (matches.length === 0) { %>
    <div class="max-w-md mx-auto text-center border-2 border-dashed border-slate-200 rounded-[28px] p-8 sm:p-12 fade-up">
      <div class="text-5xl mb-4">🔍</div>
      <h2 class="font-heading text-2xl font-bold text-slate-800">No active matches found</h2>
      <p class="text-sm text-slate-500 mt-3 leading-relaxed">
        There are currently no active tasks on campus, or they don't match your current profile parameters. Check back soon or edit your profile!
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-3 mt-8">
        <a href="/profile" class="apply-btn inline-block w-auto px-6">Edit Skills</a>
        <a href="/homes" class="apply-btn inline-block w-auto px-6 bg-white border border-slate-200 text-slate-700 hover:border-slate-300">Browse All Jobs</a>
      </div>
    </div>

  <!-- JOB MATCH GRID -->
  <% } else { %>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% matches.forEach(match => { %>
        
        <div class="match-card">
          
          <!-- IMAGE & HEADER -->
          <div class="match-card__img-wrap">
            <img src="<%= match.photo %>" alt="<%= match.houseName %>">
            
            <!-- Price badge -->
            <span class="absolute top-4 right-4 bg-slate-900/80 backdrop-blur-md border border-white/10 text-white font-heading text-xs font-bold px-3 py-1.5 rounded-full">
              ₹ <%= match.price %>
            </span>
            
            <!-- Match score tag overlay -->
            <% 
              let scoreBorder = "border-emerald-400";
              let scoreText = "text-emerald-700";
              if (match.matchScore < 80 && match.matchScore >= 50) {
                scoreBorder = "border-amber-400";
                scoreText = "text-amber-700";
              } else if (match.matchScore < 50) {
                scoreBorder = "border-slate-300";
                scoreText = "text-slate-600";
              }
            %>
            <div class="absolute top-4 left-4 flex items-center justify-center w-14 h-14 rounded-full border-4 bg-white shadow-md <%= scoreBorder %>">
              <div class="flex flex-col items-center justify-center leading-none">
                <span class="text-base font-bold font-heading <%= scoreText %>"><%= match.matchScore %></span>
                <span class="text-[8px] font-bold text-slate-400 uppercase tracking-widest mt-0.5">%</span>
              </div>
            </div>

            <!-- Job category tag -->
            <span class="badge absolute bottom-4 left-4 bg-white/95 text-slate-800 border border-slate-100 shadow-sm">
              <%= match.propertytype %>
            </span>
          </div>

          <!-- CARD BODY -->
          <div class="match-card__body">
            
            <div>
              <h3 class="job-title truncate"><%= match.houseName %></h3>
              <p class="text-xs text-slate-400 flex items-center gap-1 mt-1.5 font-medium">
                <i class="fa-solid fa-map-pin text-slate-300"></i>
                <%= match.location %>
              </p>
            </div>

            <!-- Short Job description -->
            <p class="job-desc"><%= match.description %></p>

            <!-- MATCH REASON INSIGHT BOX -->
            <div class="insight-banner <%= aiUsed ? 'insight-banner-ai' : 'insight-banner-local' %> mt-2">
              <div class="flex items-center gap-1.5 mb-1 text-[10px] font-bold tracking-wider uppercase font-heading">
                <% if (aiUsed) { %>
                  <i class="fa-solid fa-microchip"></i> AI Recommendation
                <% } else { %>
                  <i class="fa-solid fa-bolt"></i> Local Smart Fit
                <% } %>
              </div>
              <p class="text-xs font-semibold leading-relaxed">
                <%= match.matchReason %>
              </p>
            </div>

            <!-- ACTIONS -->
            <div class="mt-4 pt-4 border-t border-slate-100 flex items-center justify-between gap-3">
              <div class="text-left">
                <span class="text-[9px] text-slate-400 uppercase font-bold tracking-wider block">Rating</span>
                <span class="text-xs font-bold text-slate-800 flex items-center gap-1 mt-0.5">
                  <i class="fa-solid fa-star text-amber-400"></i>
                  <%= match.rating %>
                </span>
              </div>
              
              <a href="/homes/<%= match._id %>" class="apply-btn flex-1">
                View & Apply &rarr;
              </a>
            </div>

          </div>

        </div>

      <% }) %>
    </div>

  <% } %>

  <!-- RE-EVALUATE BUTTON -->
  <% if (!profileIncomplete && matches.length > 0) { %>
    <div class="mt-16 text-center fade-up">
      <p class="text-xs text-slate-400 font-medium">Not seeing the jobs you want?</p>
      <a href="/profile" class="inline-flex items-center gap-2 text-xs font-bold text-slate-600 hover:text-slate-900 mt-2 underline transition">
        <i class="fa-solid fa-pen-to-square"></i> Refine bio & skills tags in your profile
      </a>
    </div>
  <% } %>

</main>

  <%- include('../partials/chatbot-widget') %>

</body>
</html>
