<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/output.css" />

<%- include('../partials/head') %>

<style>
  :root {
    --brand-primary: #6366f1; /* Indigo */
    --brand-emerald: #10b981; /* Emerald */
    --brand-slate: #0f172a; /* Slate 900 */
    --bg-light: #f8fafc; /* Slate 50 */
    --border-soft: #f1f5f9; /* Slate 100 */
    --card-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.04), 0 1px 1px rgba(0, 0, 0, 0.01);
  }

  body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    background: var(--bg-light);
    color: #334155;
  }

  .font-heading { font-family: 'Outfit', sans-serif; }

  /* Premium Card Design */
  .profile-card {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(226, 232, 240, 0.8);
    border-radius: 28px;
    box-shadow: var(--card-shadow);
    transition: all 0.3s ease;
  }

  .premium-metric-card {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(226, 232, 240, 0.8);
    border-radius: 18px;
    box-shadow: var(--card-shadow);
  }

  /* Interactive Skill Tag */
  .skill-tag {
    cursor: pointer;
    font-size: 0.82rem;
    font-weight: 600;
    padding: 8px 16px;
    border-radius: 100px;
    border: 1px solid #e2e8f0;
    background: white;
    color: #64748b;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    user-select: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .skill-tag:hover {
    border-color: var(--brand-primary);
    color: var(--brand-primary);
    transform: translateY(-1px);
  }
  .skill-tag.selected {
    background: var(--brand-primary);
    color: white;
    border-color: var(--brand-primary);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);
  }

  .custom-skill-input {
    border: 1px solid #e2e8f0;
    border-radius: 100px;
    padding: 8px 18px;
    font-size: 0.84rem;
    outline: none;
    transition: all 0.2s;
    background: white;
    color: #1e293b;
  }
  .custom-skill-input:focus {
    border-color: var(--brand-primary);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
  }

  .bio-textarea {
    border: 1px solid #e2e8f0;
    border-radius: 18px;
    padding: 16px;
    font-size: 0.92rem;
    line-height: 1.6;
    outline: none;
    resize: none;
    transition: all 0.2s;
    width: 100%;
    min-height: 120px;
    background: white;
    color: #1e293b;
  }
  .bio-textarea:focus {
    border-color: var(--brand-primary);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
  }

  /* Success Banner slide-in */
  .alert-banner {
    animation: slideDown 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .save-btn {
    font-family: 'Outfit', sans-serif;
    font-size: 0.86rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: var(--brand-slate);
    color: white;
    padding: 14px 28px;
    border-radius: 16px;
    transition: all 0.2s;
    border: none;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
  }
  .save-btn:hover {
    background: #1e293b;
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.3);
  }
  .save-btn:active {
    transform: translateY(0);
  }

  .section-label {
    font-family: 'Outfit', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #94a3b8;
  }
</style>

</head>

<body class="min-h-screen">

<%- include('../partials/header', { isLoggedIn: isLoggedIn, user: user }) %>

<main class="max-w-4xl mx-auto px-5 sm:px-8 pt-32 pb-28">

  <!-- PAGE HEADER -->
  <section class="mb-8 text-center sm:text-left">
    <div class="inline-flex items-center gap-2 bg-indigo-50 border border-indigo-100 text-indigo-700 px-4 py-1.5 rounded-full text-xs font-semibold shadow-sm animate-pulse">
      <i class="fa-solid fa-user-gear"></i> Student Center
    </div>
    <h1 class="font-heading text-4xl sm:text-5xl font-extrabold mt-4 tracking-tight text-slate-900">
      My Student Profile
    </h1>
    <p class="mt-2 text-slate-500 max-w-xl text-sm sm:text-base leading-relaxed">
      Set up your bio and campus skills. Our AI engine uses these details to match you with top-paying campus gigs!
    </p>
  </section>

  <!-- STATS ROW -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
    <div class="premium-metric-card px-4 py-3 text-center">
      <p class="font-heading text-2xl font-extrabold text-emerald-600"><%= user.completedTasks || 0 %></p>
      <p class="section-label mt-1 text-[9px]">Tasks Done</p>
    </div>
    <div class="premium-metric-card px-4 py-3 text-center">
      <p class="font-heading text-2xl font-extrabold text-slate-900"><%= (user.skills || []).length %></p>
      <p class="section-label mt-1 text-[9px]">Skills</p>
    </div>
    <div class="premium-metric-card px-4 py-3 text-center">
      <p class="font-heading text-2xl font-extrabold text-indigo-600">₹<%= user.expectedPrice || 0 %></p>
      <p class="section-label mt-1 text-[9px]">Expected Rate</p>
    </div>
    <div class="premium-metric-card px-4 py-3 text-center">
      <p class="font-heading text-2xl font-extrabold text-slate-900"><%= user.distance || 0 %> km</p>
      <p class="section-label mt-1 text-[9px]">Max Distance</p>
    </div>
  </div>

  <!-- NOTIFICATIONS -->
  <% if (successMessage) { %>
    <div class="alert-banner mb-6 p-4 bg-emerald-50 border border-emerald-100 rounded-2xl flex items-center justify-between shadow-sm">
      <div class="flex items-center gap-3">
        <i class="fa-solid fa-circle-check text-emerald-600 text-lg"></i>
        <p class="text-sm text-emerald-800 font-medium"><%= successMessage %></p>
      </div>
      <a href="/smart-matches" class="text-xs bg-emerald-600 text-white font-semibold py-1.5 px-3.5 rounded-full hover:bg-emerald-700 transition">View Matches 🎯</a>
    </div>
  <% } %>

  <% if (errorMessage) { %>
    <div class="alert-banner mb-6 p-4 bg-rose-50 border border-rose-100 rounded-2xl flex items-center gap-3 shadow-sm">
      <i class="fa-solid fa-circle-exclamation text-rose-600 text-lg"></i>
      <p class="text-sm text-rose-800 font-medium"><%= errorMessage %></p>
    </div>
  <% } %>

  <!-- MAIN CARD FORM -->
  <div class="profile-card p-6 sm:p-10">
    <form action="/profile" method="POST" id="profileForm">
      
      <!-- BIO SECTION -->
      <div class="mb-8">
        <div class="flex justify-between items-center mb-3">
          <label class="section-label">Introduce Yourself (Bio)</label>
          <span class="text-xs text-slate-400 font-semibold" id="charCount">0/200</span>
        </div>
        <textarea 
          name="bio" 
          id="bioInput" 
          maxlength="200" 
          class="bio-textarea" 
          placeholder="E.g., 'I have a bicycle and a laser printer, willing to run errands on campus and print notes.' or 'CS sophomore offering tutoring in programming. Available on weekends.'"
        ><%= user.bio || '' %></textarea>
        <p class="text-xs text-slate-400 mt-2.5 leading-relaxed">
          💡 Mentioning specific assets (like a printer, bike, or camera) helps the AI match you to related tasks like stationery printing or parcel delivery.
        </p>
      </div>

      <!-- SKILLS SECTION -->
      <div class="mb-10">
        <label class="section-label block mb-4">Select or Add Campus Skills</label>
        
        <!-- Popular preset skills -->
        <div class="flex flex-wrap gap-2.5 mb-5" id="presetsContainer">
          <% 
            const popularSkills = ["Printing", "Errands", "Tutoring", "Delivery", "Coding", "Designing", "Photography", "Note-Taking", "Proofreading", "Event Help"];
            const currentSkills = user.skills || [];
            
            popularSkills.forEach(skill => {
              const isSelected = currentSkills.some(s => s.toLowerCase() === skill.toLowerCase());
          %>
            <div 
              class="skill-tag <%= isSelected ? 'selected' : '' %>" 
              onclick="togglePreset(this, '<%= skill %>')"
            >
              <%= skill %>
              <% if (isSelected) { %>
                <i class="fa-solid fa-check text-[10px]"></i>
              <% } else { %>
                <i class="fa-solid fa-plus text-[10px]"></i>
              <% } %>
            </div>
          <% }) %>

          <!-- Dynamically added custom skills will show here too -->
          <% 
            // Any user skills not in presets will render as active custom skills
            const lowerPresets = popularSkills.map(s => s.toLowerCase());
            currentSkills.forEach(skill => {
              if (!lowerPresets.includes(skill.toLowerCase())) {
          %>
            <div 
              class="skill-tag selected custom-rendered" 
              onclick="removeCustomTag(this, '<%= skill %>')"
            >
              <%= skill %>
              <i class="fa-solid fa-xmark text-[10px]"></i>
            </div>
          <% 
              }
            }); 
          %>
        </div>

        <!-- Custom skills input -->
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
          <div class="relative flex-grow sm:max-w-xs">
            <i class="fa-solid fa-tag absolute left-4 top-1/2 transform -translate-y-1/2 text-slate-300 text-xs"></i>
            <input 
              type="text" 
              id="customSkillInput" 
              class="custom-skill-input pl-9 pr-4 py-2.5 w-full rounded-2xl" 
              placeholder="Add other skill (e.g. Photoshop)..."
            />
          </div>
          <button 
            type="button" 
            onclick="addCustomSkill()" 
            class="text-xs bg-white border border-slate-200 text-slate-700 font-bold py-3 px-5 rounded-2xl hover:border-slate-400 hover:text-slate-900 transition flex items-center justify-center"
          >
            Add Tag +
          </button>
        </div>
      </div>

      <!-- PRICING, DISTANCE & LOCATION SECTION -->
      <div class="mb-10 pt-8 border-t border-slate-100">
        <label class="section-label block mb-4">Availability & Location Info</label>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

          <!-- Expected Price -->
          <div>
            <label class="section-label block mb-2">Expected Hourly Rate (₹)</label>
            <div class="relative">
              <i class="fa-solid fa-indian-rupee-sign absolute left-4 top-1/2 transform -translate-y-1/2 text-slate-300 text-xs"></i>
              <input 
                type="number" 
                name="expectedPrice" 
                id="expectedPriceInput" 
                class="custom-skill-input pl-9 pr-4 py-3 w-full rounded-2xl" 
                placeholder="e.g. 150"
                value="<%= user.expectedPrice || '' %>"
                min="0"
              />
            </div>
            <p class="text-xs text-slate-400 mt-1.5 leading-relaxed">Set your expected rate per hour or per small task.</p>
          </div>

          <!-- Distance -->
          <div>
            <label class="section-label block mb-2">Distance from Campus Center (km)</label>
            <div class="relative">
              <i class="fa-solid fa-location-dot absolute left-4 top-1/2 transform -translate-y-1/2 text-slate-300 text-xs"></i>
              <input 
                type="number" 
                step="0.1"
                name="distance" 
                id="distanceInput" 
                class="custom-skill-input pl-9 pr-4 py-3 w-full rounded-2xl" 
                placeholder="e.g. 0.5"
                value="<%= user.distance || '' %>"
                min="0"
              />
            </div>
            <p class="text-xs text-slate-400 mt-1.5 leading-relaxed">Your approximate distance from campus center.</p>
          </div>

          <!-- Location (area/hostel/neighborhood) -->
          <div class="sm:col-span-2">
            <label class="section-label block mb-2">Your Location / Area on Campus</label>
            <div class="relative">
              <i class="fa-solid fa-map-pin absolute left-4 top-1/2 transform -translate-y-1/2 text-slate-300 text-xs"></i>
              <input 
                type="text" 
                name="location" 
                id="locationInput" 
                class="custom-skill-input pl-9 pr-4 py-3 w-full rounded-2xl" 
                placeholder="e.g. Boys Hostel Block C, or Main Gate Area"
                value="<%= user.location || '' %>"
              />
            </div>
            <p class="text-xs text-slate-400 mt-1.5 leading-relaxed">Helps hosts understand your availability zone within campus.</p>
          </div>

        </div>
      </div>

      <!-- HIDDEN INPUT TO TRANSMIT SKILLS ARRAY AS COMMA SEPARATED LIST -->
      <input type="hidden" name="skills" id="skillsOutput" value="<%= currentSkills.join(',') %>" />

      <!-- SUBMIT -->
      <div class="flex flex-col sm:flex-row items-center justify-between border-t border-slate-100 pt-8 gap-6">
        <div class="flex items-center gap-3 text-left">
          <div class="w-10 h-10 bg-indigo-50 border border-indigo-100 text-indigo-600 rounded-full flex items-center justify-center text-sm font-semibold shadow-sm animate-pulse">
            🎯
          </div>
          <div>
            <p class="text-[9px] text-slate-400 uppercase tracking-wider font-bold">Matching status</p>
            <p class="text-xs font-semibold text-slate-600 mt-0.5 leading-relaxed">
              <%= currentSkills.length %> Skills Active • AI Engine Ready
              <% if ((user.completedTasks || 0) > 0) { %>
              • 🏆 <%= user.completedTasks %> Task<%= user.completedTasks > 1 ? 's' : '' %> Completed
              <% } %>
            </p>
          </div>
        </div>

        <button type="submit" class="save-btn w-full sm:w-auto flex items-center justify-center gap-2">
          Save Profile Details <i class="fa-solid fa-arrow-right text-[10px]"></i>
        </button>
      </div>

    </form>
  </div>

</main>

<script>
  // Character count tracker
  const bioInput = document.getElementById('bioInput');
  const charCount = document.getElementById('charCount');
  
  function updateCount() {
    charCount.textContent = `${bioInput.value.length}/200`;
  }
  bioInput.addEventListener('input', updateCount);
  updateCount(); // Init

  // Skills array state management
  let activeSkills = "<%= currentSkills.join(',') %>".split(',').filter(s => s.length > 0);
  const skillsOutput = document.getElementById('skillsOutput');

  function updateHiddenOutput() {
    skillsOutput.value = activeSkills.join(',');
  }

  // Toggle presets
  function togglePreset(el, skill) {
    const isSelected = el.classList.contains('selected');
    const cleanSkill = skill.trim();

    if (isSelected) {
      // Remove
      el.classList.remove('selected');
      activeSkills = activeSkills.filter(s => s.toLowerCase() !== cleanSkill.toLowerCase());
      el.innerHTML = `${skill} <i class="fa-solid fa-plus text-[10px]"></i>`;
    } else {
      // Add
      el.classList.add('selected');
      if (!activeSkills.some(s => s.toLowerCase() === cleanSkill.toLowerCase())) {
        activeSkills.push(cleanSkill);
      }
      el.innerHTML = `${skill} <i class="fa-solid fa-check text-[10px]"></i>`;
    }
    updateHiddenOutput();
  }

  // Add custom skill dynamically
  const customInput = document.getElementById('customSkillInput');
  const presetsContainer = document.getElementById('presetsContainer');

  function addCustomSkill() {
    const value = customInput.value.trim();
    if (!value) return;

    // Check if already exists in active list
    if (activeSkills.some(s => s.toLowerCase() === value.toLowerCase())) {
      customInput.value = '';
      return;
    }

    activeSkills.push(value);
    updateHiddenOutput();

    // Create a new visual tag
    const newTag = document.createElement('div');
    newTag.className = 'skill-tag selected custom-rendered animate-pulse';
    newTag.innerHTML = `${value} <i class="fa-solid fa-xmark text-[10px]"></i>`;
    
    // Wire up removing
    newTag.onclick = function() {
      removeCustomTag(newTag, value);
    };

    presetsContainer.appendChild(newTag);
    setTimeout(() => newTag.classList.remove('animate-pulse'), 500);
    
    customInput.value = '';
  }

  function removeCustomTag(el, skill) {
    el.remove();
    activeSkills = activeSkills.filter(s => s.toLowerCase() !== skill.toLowerCase());
    updateHiddenOutput();
  }

  // Trigger addCustomSkill on typing Enter key
  customInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      addCustomSkill();
    }
  });
</script>

  <%- include('../partials/chatbot-widget') %>

</body>
</html>
