
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/output.css" />

  <%- include('../partials/head') %>
  </head>

  <body
    class="min-h-screen bg-gradient-to-b from-[#fff1f2] via-white to-[#f7f7f7] font-sans"
  >

  <%- include('../partials/header') %> 
  <%- include('../partials/header', { 
      isLoggedIn: isLoggedIn, 
      user: user 
}) %>



<section class="max-w-7xl mx-auto px-6 mb-16">
  <h1 class="text-6xl md:text-5xl font-semibold text-green-700 mb-3">
    Saved Tasks
  </h1>
  <p class="text-gray-500 max-w-2xl">
    All the tasks you saved in one place. Easily access, compare, and apply when you're ready.
  </p>
</section>

<!-- Info strip -->
<section class="max-w-7xl mx-auto px-6 mb-12">
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 bg-white rounded-2xl shadow-sm border p-6">
    <p class="text-gray-600 text-sm">
      🔖 Tip: Save tasks to quickly revisit them and choose the best opportunity.
    </p>
    <a
      href="/"
      class="text-sm font-medium text-green-600 hover:underline"
    >
      Browse more tasks →
    </a>
  </div>
</section>

<!-- Tasks Grid -->
<section class="max-w-7xl mx-auto px-6">
  <ul class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">

    <% favouriteHomes.forEach(home => { %>

    <li class="group bg-white rounded-3xl overflow-hidden shadow-md hover:shadow-2xl transition duration-300">

      <!-- Image -->
      <div class="relative h-60 overflow-hidden">
        <img
          src="<%= home.photo %>"
          alt="<%= home.houseName %>"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />

        <!-- Reward -->
        <span class="absolute top-4 left-4 bg-white/90 backdrop-blur px-4 py-1 rounded-full text-sm font-semibold text-gray-800 shadow">
          ₹ <%= home.price %> reward
        </span>

        <!-- Saved Icon -->
        <span class="absolute top-4 right-4 bg-white/90 backdrop-blur p-2 rounded-full shadow text-green-600">
          🔖
        </span>
      </div>

      <!-- Content -->
      <div class="p-6">

        <div class="flex items-start justify-between mb-2">
          <h3 class="text-xl font-semibold text-gray-900 leading-tight">
            <%= home.houseName %>
          </h3>

          <span class="flex items-center gap-1 text-yellow-500 text-sm font-semibold">
            ⭐ <%= home.rating %> trust
          </span>
        </div>

        <p class="text-gray-500 text-sm mb-5">📍 <%= home.location %></p>

        <div class="h-px bg-gray-200 mb-5"></div>

        <!-- Actions -->
        <div class="flex items-center justify-between gap-3">

          <a
            href="/homes/<%= home._id %>"
            class="flex-1 text-center px-4 py-2 rounded-lg text-sm font-medium
                   border border-gray-300 text-gray-700
                   hover:border-green-600 hover:text-green-600
                   transition"
          >
            View Task
          </a>

          <form action="/favourites/delete/<%= home._id %>" method="POST" class="flex-1">
            <button
              type="submit"
              class="w-full px-4 py-2 rounded-lg text-sm font-medium
                     bg-red-500 text-white
                     hover:bg-red-600 transition"
            >
              Remove
            </button>
          </form>

        </div>
      </div>
    </li>

    <% }) %>

  </ul>
</section>

</main>



  </body>
</html>
