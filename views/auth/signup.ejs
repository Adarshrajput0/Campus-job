<!DOCTYPE html>
<html lang="en">
<head>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  
  <%- include('../partials/head', { pageTitle: 'Signup - Campus Gigs' }) %>
  
  <style>
    :root {
      --brand-primary: #6366f1;
      --brand-emerald: #10b981;
      --brand-slate: #0f172a;
      --bg-light: #f8fafc;
      --border-soft: #f1f5f9;
      --card-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.04), 0 1px 1px rgba(0, 0, 0, 0.01);
    }
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg-light);
      color: #334155;
    }
    .font-heading { font-family: 'Outfit', sans-serif; }
    .premium-card {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(226, 232, 240, 0.8);
      box-shadow: var(--card-shadow);
    }
    /* Clerk component container overrides */
    #clerk-sign-up {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 100%;
    }
    #clerk-sign-up .cl-card {
      box-shadow: none !important;
      border: none !important;
      background: transparent !important;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.55s cubic-bezier(0.16,1,0.3,1) both; }
    .d1 { animation-delay: 0.1s; }
    .d2 { animation-delay: 0.2s; }

    /* Loading skeleton while Clerk loads */
    .clerk-loading {
      display: flex;
      flex-direction: column;
      gap: 14px;
      padding: 8px 0;
    }
    .skel {
      border-radius: 12px;
      background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
      background-size: 200% 100%;
      animation: shimmer 1.4s infinite;
    }
    @keyframes shimmer {
      0%   { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }
  </style>

  <!-- Clerk JS — embed sign-up on this page -->
  <script
    async
    crossorigin="anonymous"
    data-clerk-publishable-key="<%= clerkPublishableKey %>"
    src="https://cdn.jsdelivr.net/npm/@clerk/clerk-js@5/dist/clerk.browser.js"
    type="text/javascript"
  ></script>
</head>

<body class="min-h-screen flex flex-col">

  <!-- NAVBAR HEADER -->
  <%- include('../partials/header', { isLoggedIn: isLoggedIn, user: user }) %>

  <!-- SPLIT CONTENT SHELL -->
  <div class="flex-grow grid grid-cols-1 md:grid-cols-12 pt-16">

    <!-- LEFT: BRAND PANEL (Visible on MD and up) -->
    <div class="hidden md:flex md:col-span-5 lg:col-span-4 bg-slate-950 text-white flex-col justify-between p-10 lg:p-12 relative overflow-hidden">
      <!-- Ambient decorative elements -->
      <div class="absolute -top-24 -right-24 w-80 h-80 rounded-full bg-indigo-500/10 blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-20 -left-20 w-64 h-64 rounded-full bg-emerald-500/10 blur-2xl pointer-events-none"></div>

      <div class="relative z-10 my-auto space-y-8">
        <div class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-500/20 text-indigo-300 px-4 py-1.5 rounded-full text-xs font-semibold shadow-sm">
          <span class="w-2 h-2 rounded-full bg-indigo-400 animate-pulse"></span>
          Join the Platform
        </div>
        
        <h2 class="font-heading text-4xl lg:text-5xl font-extrabold leading-[1.1] tracking-tight">
          Start earning<br>on <span class="bg-gradient-to-r from-indigo-400 to-emerald-400 bg-clip-text text-transparent">your campus</span><br>today.
        </h2>
        <p class="text-sm lg:text-base text-slate-400 max-w-sm leading-relaxed">
          Create an account to post tasks, find micro-gigs, and connect with your campus community.
        </p>

        <!-- Steps display -->
        <div class="space-y-4 pt-4">
          <div class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-slate-800 border border-slate-700 text-indigo-400 text-xs font-bold flex items-center justify-center flex-shrink-0 mt-0.5">1</span>
            <div class="text-xs">
              <strong class="text-slate-200 block font-semibold">Create your account</strong>
              <span class="text-slate-500">Takes less than a minute.</span>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-slate-800 border border-slate-700 text-indigo-400 text-xs font-bold flex items-center justify-center flex-shrink-0 mt-0.5">2</span>
            <div class="text-xs">
              <strong class="text-slate-200 block font-semibold">Pick your role</strong>
              <span class="text-slate-500">Join as a student Helper or a Host.</span>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-slate-800 border border-slate-700 text-indigo-400 text-xs font-bold flex items-center justify-center flex-shrink-0 mt-0.5">3</span>
            <div class="text-xs">
              <strong class="text-slate-200 block font-semibold">Start earning</strong>
              <span class="text-slate-500">Browse live jobs and apply instantly.</span>
            </div>
          </div>
        </div>
      </div>

      <p class="relative z-10 text-[10px] text-slate-600 font-semibold tracking-wider uppercase font-heading">
        © Campus Jobs Platform
      </p>
    </div>

    <!-- RIGHT: CLERK SIGN-UP PANEL -->
    <div class="col-span-1 md:col-span-7 lg:col-span-8 flex flex-col items-center justify-center p-6 sm:p-12 bg-slate-50 overflow-y-auto">
      
      <div class="w-full max-w-md fade-up d1">
        
        <div class="mb-6 text-center md:text-left">
          <h1 class="font-heading text-3xl font-extrabold text-slate-900 tracking-tight">Create Account</h1>
          <p class="text-sm text-slate-500 mt-1">Join the Campus Jobs community.</p>
        </div>

        <!-- Clerk Sign-Up Component -->
        <div id="clerk-loading" class="clerk-loading mb-2">
          <div class="skel h-11 w-full"></div>
          <div class="skel h-11 w-full"></div>
          <div class="skel h-11 w-full"></div>
          <div class="skel h-12 w-full mt-2"></div>
        </div>
        <div id="clerk-sign-up" class="hidden"></div>

        <p class="text-center text-[11px] text-slate-400 mt-6">
          Already have an account?
          <a href="/login" class="text-indigo-600 font-bold hover:underline ml-1">Log in here →</a>
        </p>

      </div>

    </div>

  </div>

  <script>
    window.addEventListener("load", async function () {
      try {
        const origin = window.location.origin;
        await Clerk.load();
        document.getElementById('clerk-loading').style.display = 'none';
        document.getElementById('clerk-sign-up').classList.remove('hidden');
        Clerk.mountSignUp(document.getElementById('clerk-sign-up'), {
          afterSignInUrl: origin + '/sso-callback',
          afterSignUpUrl: origin + '/sso-callback',
          signInUrl: origin + '/login',
          appearance: {
            elements: {
              card: 'shadow-none border-0 bg-transparent p-0',
              formButtonPrimary: 'bg-slate-900 hover:bg-indigo-600 font-heading uppercase tracking-wider text-xs transition-all',
              footerActionLink: 'text-indigo-600 font-bold hover:text-indigo-700',
            }
          }
        });
      } catch (err) {
        console.error('Clerk load error:', err);
        document.getElementById('clerk-loading').innerHTML = '<p class="text-sm text-red-500 text-center py-4">Failed to load sign-up. Please refresh.</p>';
      }
    });
  </script>

</body>
</html>
