<!DOCTYPE html>
<html lang="en">
<head>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  
  <%- include('../partials/head', { pageTitle: 'Signup - Campus Gigs' }) %>
  
  <style>
    :root {
      --brand-primary: #6366f1;
      --brand-emerald: #10b981;
      --brand-slate: #0f172a;
      --bg-light: #f8fafc;
      --border-soft: #f1f5f9;
      --card-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.04), 0 1px 1px rgba(0, 0, 0, 0.01);
    }
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg-light);
      color: #334155;
    }
    .font-heading { font-family: 'Outfit', sans-serif; }
    .premium-card {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(226, 232, 240, 0.8);
      box-shadow: var(--card-shadow);
    }
    .input-form-field {
      width: 100%;
      padding: 12px 14px 12px 40px;
      border: 1px solid #e2e8f0;
      border-radius: 14px;
      background: white;
      outline: none;
      font-size: 0.88rem;
      color: #1e293b;
      transition: all 0.2s;
    }
    .input-form-field:focus {
      border-color: var(--brand-primary);
      box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
    }
  </style>
</head>

<body class="min-h-screen flex flex-col">

  <!-- NAVBAR HEADER -->
  <%- include('../partials/header', { isLoggedIn: isLoggedIn, user: user }) %>

  <!-- SPLIT CONTENT SHELL -->
  <div class="flex-grow grid grid-cols-1 md:grid-cols-12 pt-16">

    <!-- LEFT: BRAND PANEL (Visible on MD and up) -->
    <div class="hidden md:flex md:col-span-5 lg:col-span-4 bg-slate-950 text-white flex-col justify-between p-10 lg:p-12 relative overflow-hidden">
      <!-- Ambient decorative elements -->
      <div class="absolute -top-24 -right-24 w-80 h-80 rounded-full bg-indigo-500/10 blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-20 -left-20 w-64 h-64 rounded-full bg-emerald-500/10 blur-2xl pointer-events-none"></div>

      <div class="relative z-10 my-auto space-y-8">
        <div class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-500/20 text-indigo-300 px-4 py-1.5 rounded-full text-xs font-semibold shadow-sm">
          <span class="w-2 h-2 rounded-full bg-indigo-400 animate-pulse"></span>
          Join the Platform
        </div>
        
        <h2 class="font-heading text-4xl lg:text-5xl font-extrabold leading-[1.1] tracking-tight">
          Start earning<br>on <span class="bg-gradient-to-r from-indigo-400 to-emerald-400 bg-clip-text text-transparent">your campus</span><br>today.
        </h2>
        <p class="text-sm lg:text-base text-slate-400 max-w-sm leading-relaxed">
          Create an account to post tasks, find micro-gigs, and connect with your campus community.
        </p>

        <!-- Steps display -->
        <div class="space-y-4 pt-4">
          <div class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-slate-800 border border-slate-700 text-indigo-400 text-xs font-bold flex items-center justify-center flex-shrink-0 mt-0.5">1</span>
            <div class="text-xs">
              <strong class="text-slate-200 block font-semibold">Create your account</strong>
              <span class="text-slate-500">Takes less than a minute.</span>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-slate-800 border border-slate-700 text-indigo-400 text-xs font-bold flex items-center justify-center flex-shrink-0 mt-0.5">2</span>
            <div class="text-xs">
              <strong class="text-slate-200 block font-semibold">Pick your role</strong>
              <span class="text-slate-500">Join as a student Helper or a Host.</span>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-slate-800 border border-slate-700 text-indigo-400 text-xs font-bold flex items-center justify-center flex-shrink-0 mt-0.5">3</span>
            <div class="text-xs">
              <strong class="text-slate-200 block font-semibold">Start earning</strong>
              <span class="text-slate-500">Browse live jobs and apply instantly.</span>
            </div>
          </div>
        </div>
      </div>

      <p class="relative z-10 text-[10px] text-slate-600 font-semibold tracking-wider uppercase font-heading">
        © Campus Jobs Platform
      </p>
    </div>

    <!-- RIGHT: FORM PANEL -->
    <div class="col-span-1 md:col-span-7 lg:col-span-8 flex items-center justify-center p-6 sm:p-10 bg-slate-50 overflow-y-auto">
      
      <div class="premium-card p-8 sm:p-10 rounded-[28px] max-w-md w-full shadow-lg my-8">
        
        <div class="mb-8">
          <h2 class="font-heading text-3xl font-extrabold text-slate-900">Create Account</h2>
          <p class="text-xs text-slate-500 mt-2">
            Already have an account? 
            <a href="/login" class="text-indigo-600 hover:underline font-bold ml-1">Log in</a>
          </p>
        </div>

        <form action="/signup" method="POST" class="space-y-4">

          <!-- ERRORS -->
          <% if (errors.length > 0) { %>
          <div class="p-4 bg-rose-50 border-l-4 border-rose-500 rounded-r-xl flex items-start gap-3 shadow-sm mb-4">
            <i class="fa-solid fa-circle-exclamation text-rose-600 text-lg mt-0.5"></i>
            <div>
              <p class="text-xs font-bold text-rose-800 font-heading">Please fix the following:</p>
              <ul class="list-disc pl-5 mt-1 text-[11px] text-rose-700 space-y-0.5">
                <% errors.slice(0,5).forEach(error => { %>
                  <li><%= error %></li>
                <% }) %>
              </ul>
            </div>
          </div>
          <% } %>

          <!-- FIRST / LAST NAME ROW -->
          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-2">
              <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block font-heading" for="firstName">First Name</label>
              <div class="relative">
                <i class="fa-regular fa-user absolute left-4 top-1/2 transform -translate-y-1/2 text-slate-300"></i>
                <input
                  type="text"
                  id="firstName"
                  name="firstName"
                  class="input-form-field"
                  placeholder="John"
                  value="<%= oldInput.firstName || '' %>"
                  required
                />
              </div>
            </div>
            <div class="space-y-2">
              <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block font-heading" for="lastName">Last Name</label>
              <div class="relative">
                <i class="fa-regular fa-user absolute left-4 top-1/2 transform -translate-y-1/2 text-slate-300"></i>
                <input
                  type="text"
                  id="lastName"
                  name="lastName"
                  class="input-form-field"
                  placeholder="Doe"
                  value="<%= oldInput.lastName || '' %>"
                  required
                />
              </div>
            </div>
          </div>

          <!-- EMAIL -->
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block font-heading" for="email">Email Address</label>
            <div class="relative">
              <i class="fa-regular fa-envelope absolute left-4 top-1/2 transform -translate-y-1/2 text-slate-300"></i>
              <input
                type="email"
                id="email"
                name="email"
                class="input-form-field"
                placeholder="you@university.edu"
                value="<%= oldInput.email || '' %>"
                required
              />
            </div>
          </div>

          <!-- PASSWORD -->
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block font-heading" for="password">Password</label>
            <div class="relative">
              <i class="fa-solid fa-lock absolute left-4 top-1/2 transform -translate-y-1/2 text-slate-300"></i>
              <input
                type="password"
                id="password"
                name="password"
                class="input-form-field"
                placeholder="Create a password"
                required
              />
            </div>
          </div>

          <!-- CONFIRM PASSWORD -->
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block font-heading" for="confirmPassword">Confirm Password</label>
            <div class="relative">
              <i class="fa-solid fa-lock absolute left-4 top-1/2 transform -translate-y-1/2 text-slate-300"></i>
              <input
                type="password"
                id="confirmPassword"
                name="confirmPassword"
                class="input-form-field"
                placeholder="Repeat your password"
                required
              />
            </div>
          </div>

          <!-- ROLE SELECTOR -->
          <div class="space-y-2 pt-1">
            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block font-heading">Register As</span>
            
            <div class="grid grid-cols-2 gap-3">
              <label class="relative block cursor-pointer">
                <input 
                  type="radio" 
                  name="userType" 
                  value="guest" 
                  class="peer sr-only" 
                  <%= oldInput.userType === 'guest' ? 'checked' : '' %> 
                  required 
                />
                <div class="p-4 border border-slate-200 rounded-2xl text-center hover:border-slate-300 transition duration-200 peer-checked:border-indigo-500 peer-checked:bg-indigo-50/50 peer-checked:text-indigo-600 flex flex-col items-center gap-1.5 font-heading text-slate-500">
                  <i class="fa-solid fa-user-graduate text-lg"></i>
                  <span class="text-xs font-bold uppercase tracking-wider">Helper</span>
                </div>
              </label>
              
              <label class="relative block cursor-pointer">
                <input 
                  type="radio" 
                  name="userType" 
                  value="host" 
                  class="peer sr-only" 
                  <%= oldInput.userType === 'host' ? 'checked' : '' %> 
                />
                <div class="p-4 border border-slate-200 rounded-2xl text-center hover:border-slate-300 transition duration-200 peer-checked:border-indigo-500 peer-checked:bg-indigo-50/50 peer-checked:text-indigo-600 flex flex-col items-center gap-1.5 font-heading text-slate-500">
                  <i class="fa-solid fa-house-user text-lg"></i>
                  <span class="text-xs font-bold uppercase tracking-wider">Host</span>
                </div>
              </label>
            </div>
          </div>

          <!-- TERMS CHECKBOX -->
          <div class="flex items-start gap-2.5 text-xs text-slate-500 pt-2 select-none">
            <input 
              type="checkbox" 
              name="terms" 
              id="terms" 
              class="w-4 h-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500 accent-indigo-600 mt-0.5 cursor-pointer" 
              required 
            />
            <label for="terms" class="cursor-pointer">
              I agree to the <a href="#" class="text-indigo-600 font-semibold hover:underline">Terms &amp; Conditions</a>
            </label>
          </div>

          <!-- SUBMIT -->
          <button type="submit" class="w-full bg-slate-900 hover:bg-slate-800 text-white font-heading text-xs font-bold uppercase tracking-wider py-4 rounded-xl transition shadow-md hover:shadow-indigo-500/10 flex items-center justify-center gap-2 mt-4">
            Register <i class="fa-solid fa-arrow-right text-[10px]"></i>
          </button>

          <!-- PLATFORM BRAND STAMP -->
          <div class="flex items-center gap-2 py-2 mt-4">
            <div class="flex-1 h-px bg-slate-100"></div>
            <span class="text-[9px] font-bold text-slate-300 uppercase tracking-widest font-heading">Campus Jobs Platform</span>
            <div class="flex-1 h-px bg-slate-100"></div>
          </div>

        </form>
      </div>

    </div>

  </div>

</body>
</html>
