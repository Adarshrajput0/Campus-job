<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Signup</title>

  <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family: "Poppins", sans-serif;
    }

    body{
      min-height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      background: linear-gradient(135deg,#0f172a,#1e293b,#111827);
      padding:30px;
    }

    .container{
      width:100%;
      max-width:520px;
      background: rgba(255,255,255,0.08);
      border:1px solid rgba(255,255,255,0.15);
      backdrop-filter: blur(20px);
      border-radius:24px;
      padding:40px;
      box-shadow:0 20px 50px rgba(0,0,0,0.4);
      color:white;
    }

    .logo{
      width:80px;
      height:80px;
      margin:auto;
      border-radius:50%;
      background: linear-gradient(135deg,#3b82f6,#8b5cf6);
      display:flex;
      justify-content:center;
      align-items:center;
      font-size:32px;
      margin-bottom:20px;
      box-shadow:0 10px 25px rgba(59,130,246,0.4);
    }

    h2{
      text-align:center;
      margin-bottom:30px;
      font-size:32px;
      font-weight:700;
    }

    .row{
      display:flex;
      gap:15px;
    }

    .form-group{
      margin-bottom:20px;
      width:100%;
    }

    .form-group label{
      display:block;
      margin-bottom:8px;
      font-size:14px;
      color:#d1d5db;
    }

    .input-box{
      position:relative;
    }

    .input-box i{
      position:absolute;
      top:50%;
      left:15px;
      transform:translateY(-50%);
      color:#94a3b8;
      font-size:15px;
    }

    .input-box input{
      width:100%;
      padding:15px 15px 15px 45px;
      border:none;
      outline:none;
      border-radius:14px;
      background: rgba(255,255,255,0.08);
      color:white;
      font-size:15px;
      border:1px solid transparent;
      transition:0.3s;
    }

    .input-box input::placeholder{
      color:#94a3b8;
    }

    .input-box input:focus{
      border-color:#60a5fa;
      background: rgba(255,255,255,0.12);
      box-shadow:0 0 0 4px rgba(96,165,250,0.2);
    }

    .radio-box{
      margin:20px 0;
      padding:18px;
      border-radius:16px;
      background: rgba(255,255,255,0.05);
      border:1px solid rgba(255,255,255,0.08);
    }

    .radio-box strong{
      display:block;
      margin-bottom:12px;
      color:#f1f5f9;
    }

    .radio-box label{
      margin-right:20px;
      font-size:15px;
      color:#dbeafe;
    }

    .radio-box input{
      margin-right:6px;
      accent-color:#3b82f6;
    }

    .terms{
      display:flex;
      align-items:center;
      gap:10px;
      margin-bottom:25px;
      font-size:14px;
      color:#cbd5e1;
    }

    .terms input{
      accent-color:#3b82f6;
      width:16px;
      height:16px;
    }

    .terms a{
      color:#60a5fa;
      text-decoration:none;
    }

    .terms a:hover{
      text-decoration:underline;
    }

    .btn{
      width:100%;
      padding:16px;
      border:none;
      border-radius:14px;
      background: linear-gradient(135deg,#2563eb,#7c3aed);
      color:white;
      font-size:16px;
      font-weight:600;
      cursor:pointer;
      transition:0.3s;
      box-shadow:0 10px 20px rgba(37,99,235,0.3);
    }

    .btn:hover{
      transform:translateY(-2px);
      box-shadow:0 15px 30px rgba(37,99,235,0.45);
    }

    .login-link{
      text-align:center;
      margin-top:22px;
      color:#cbd5e1;
      font-size:15px;
    }

    .login-link a{
      color:#60a5fa;
      text-decoration:none;
      font-weight:600;
    }

    .login-link a:hover{
      text-decoration:underline;
    }

    .error-alert{
      background: rgba(239,68,68,0.12);
      border:1px solid rgba(239,68,68,0.35);
      padding:18px;
      border-radius:16px;
      margin-bottom:22px;
    }

    .error-header{
      color:#fca5a5;
      font-weight:600;
      margin-bottom:10px;
    }

    .error-list{
      padding-left:20px;
      color:#fecaca;
      font-size:14px;
    }

    @media(max-width:600px){

      .container{
        padding:30px 22px;
      }

      .row{
        flex-direction:column;
        gap:0;
      }

      h2{
        font-size:28px;
      }

    }

  </style>
</head>

<body>

  <div class="container">

    <div class="logo">
      <i class="fa-solid fa-house-user"></i>
    </div>

    <h2>Create Account</h2>

    <form action="/signup" method="POST">

      <% if ( errors.length > 0) { %>

      <div class="error-alert">

        <div class="error-header">
          <i class="fas fa-exclamation-circle"></i>
          Please fix the following errors
        </div>

        <ul class="error-list">
          <% errors.slice(0,5).forEach(error => { %>
            <li><%= error %></li>
          <% }) %>
        </ul>

      </div>

      <% } %>

      <div class="row">

        <div class="form-group">
          <label>First Name</label>

          <div class="input-box">
            <i class="fa-solid fa-user"></i>

            <input
              type="text"
              name="firstName"
              value="<%= oldInput.firstName || '' %>"
              placeholder="John"
              required
            />
          </div>
        </div>

        <div class="form-group">
          <label>Last Name</label>

          <div class="input-box">
            <i class="fa-solid fa-user"></i>

            <input
              type="text"
              name="lastName"
              value="<%= oldInput.lastName || '' %>"
              placeholder="Doe"
              required
            />
          </div>
        </div>

      </div>

      <div class="form-group">

        <label>Email Address</label>

        <div class="input-box">
          <i class="fa-solid fa-envelope"></i>

          <input
            type="email"
            name="email"
            value="<%= oldInput.email || '' %>"
            placeholder="email@example.com"
            required
          />
        </div>

      </div>

      <div class="form-group">

        <label>Password</label>

        <div class="input-box">
          <i class="fa-solid fa-lock"></i>

          <input
            type="password"
            name="password"
            placeholder="Enter your password"
            required
          />
        </div>

      </div>

      <div class="form-group">

        <label>Confirm Password</label>

        <div class="input-box">
          <i class="fa-solid fa-lock"></i>

          <input
            type="password"
            name="confirmPassword"
            placeholder="Confirm your password"
            required
          />
        </div>

      </div>

      <div class="radio-box">

        <strong>I want to register as:</strong>

        <label>
          <input
            type="radio"
            name="userType"
            value="guest"
            <%= oldInput.userType === 'guest' ? 'checked' : '' %>
          />
          Guest
        </label>

        <label>
          <input
            type="radio"
            name="userType"
            value="host"
            <%= oldInput.userType === 'host' ? 'checked' : '' %>
          />
          Host
        </label>

      </div>

      <div class="terms">

        <input type="checkbox" name="terms" required />

        <span>
          I agree to the <a href="#">Terms & Conditions</a>
        </span>

      </div>

      <button class="btn">
        Register →
      </button>

    </form>

    <div class="login-link">
      Already have an account?
      <a href="/login">Log in</a>
    </div>

  </div>

</body>
</html>