<header>
  
  <nav class="navbar">
    <div class="nav-container">
      
      <!-- LOGO -->
      <a href="/" class="logo">
        <svg viewBox="0 0 24 24" fill="currentColor" class="logo-icon">
          <path
            d="M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7zm0 9.5c-1.4 0-2.5-1.1-2.5-2.5S10.6 6.5 12 6.5s2.5 1.1 2.5 2.5S13.4 11.5 12 11.5z"
          />
        </svg>
        <span>CampusTasks</span>
      </a>

      <!-- RIGHT -->
      <div class="nav-right">

        <% if (isLoggedIn) { %>
          <% if (typeof user !== 'undefined' && user && user.userType === 'guest') { %>

  <a href="/homes" class="nav-link bold">
    <i class="fa-solid fa-list-check"></i> Tasks
  </a>

  <a href="/favourites" class="nav-link bold">
    <i class="fa-solid fa-bookmark"></i> Saved
  </a>

  <a href="/bookings" class="nav-link bold">
    <i class="fa-solid fa-clipboard-check"></i> My Tasks
  </a>

<% } else { %>

  <a href="/host-home-list" class="nav-link bold">
    <i class="fa-solid fa-bars-progress"></i> Dashboard
  </a>

  <a href="/add-home" class="add-home-btn">
    <i class="fa-solid fa-plus"></i> Post Task
  </a>

<% } %>

<% } else { %>

  <a href="/login" class="login-btn">Login</a>
  <a href="/signup" class="signup-btn">Signup</a>

<% } %>

<form action="/logout" method="POST">
  <button type="submit" class="logout-btn">
    <i class="fa-solid fa-right-from-bracket"></i> Logout
  </button>
</form>

      </div>
    </div>
  </nav>
</header>

<style>
/* NAVBAR */
.navbar {
  position: fixed;
  top: 0;
  width: 100%;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(14px);
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
  z-index: 999;
}

.nav-container {
  max-width: 1250px;
  margin: auto;
  padding: 18px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* LOGO */
.logo {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 28px;
  font-weight: 900;
  color: #16a34a; /* green theme */
  text-decoration: none;
  transition: 0.2s;
}

.logo:hover {
  transform: translateY(-2px);
}

.logo-icon {
  width: 28px;
  height: 28px;
}

/* RIGHT SIDE */
.nav-right {
  display: flex;
  align-items: center;
  gap: 14px;
}

/* NAV LINKS */
.nav-link {
  padding: 8px 16px;
  border-radius: 30px;
  text-decoration: none;
  color: #444;
  font-weight: 600;
  font-size: 14px;
  transition: 0.25s ease;
}

.nav-link:hover {
  background: #dcfce7;
  color: #16a34a;
}

/* POST TASK BUTTON */
.add-home-btn {
  background: #16a34a;
  color: white;
  padding: 10px 18px;
  border-radius: 30px;
  text-decoration: none;
  font-weight: 700;
  font-size: 14px;
  box-shadow: 0 10px 18px rgba(22, 163, 74, 0.25);
  transition: 0.25s;
}

.add-home-btn:hover {
  background: #15803d;
  transform: translateY(-2px);
}

/* LOGIN / SIGNUP */
.login-btn,
.signup-btn {
  text-decoration: none;
  background: #16a34a;
  color: white;
  padding: 10px 18px;
  border-radius: 30px;
  font-weight: 700;
  box-shadow: 0 10px 18px rgba(22, 163, 74, 0.25);
  transition: 0.25s;
}

.signup-btn:hover,
.login-btn:hover {
  background: #15803d;
  transform: translateY(-2px);
}

/* LOGOUT */
.logout-btn {
  background: #ef4444;
  color: white;
  padding: 10px 18px;
  border-radius: 30px;
  border: none;
  font-weight: 700;
  cursor: pointer;
  transition: 0.25s;
}

.logout-btn:hover {
  background: #dc2626;
  transform: translateY(-2px);
}

.bold {
  font-weight: 700;
  font-size: larger;
}

.nav-link i,
.add-home-btn i,
.logout-btn i {
  margin-right: 6px;
}
</style>