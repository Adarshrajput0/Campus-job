<header>
  <nav class="navbar">
    <div class="nav-container">

      <!-- LOGO → always goes home -->
      <a href="/" class="logo">
        <div class="logo-icon-wrap">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7zm0 9.5c-1.4 0-2.5-1.1-2.5-2.5S10.6 6.5 12 6.5s2.5 1.1 2.5 2.5S13.4 11.5 12 11.5z"/>
          </svg>
        </div>
        <span>Campus Job</span>
      </a>

      <!-- RIGHT -->
      <div class="nav-right">

        <% if (isLoggedIn) { %>
          <% if (typeof user !== 'undefined' && user && user.userType === 'guest') { %>

            <a href="/homes" class="nav-link">
              <i class="fa-solid fa-list-check"></i> Tasks
            </a>
            <a href="/smart-matches" class="nav-link">
              <i class="fa-solid fa-circle-nodes text-[var(--lime-dark)]"></i> Smart Matches
            </a>
            <a href="/favourites" class="nav-link">
              <i class="fa-solid fa-bookmark"></i> Saved
            </a>
            <a href="/bookings" class="nav-link">
              <i class="fa-solid fa-clipboard-check"></i> My Tasks
            </a>
            <a href="/profile" class="nav-link">
              <i class="fa-solid fa-user-gear"></i> Profile
            </a>

          <% } else { %>

            <a href="/host-home-list" class="nav-link">
              <i class="fa-solid fa-bars-progress"></i> Dashboard
            </a>
            <a href="/add-home" class="nav-cta">
              <i class="fa-solid fa-plus"></i> Post Task
            </a>

          <% } %>
        <% } else { %>

          <a href="/login" class="nav-ghost">Login</a>
          <a href="/signup" class="nav-cta">Signup</a>

        <% } %>

        <form action="/logout" method="POST">
          <button type="submit" class="nav-logout">
            <i class="fa-solid fa-right-from-bracket"></i>
          </button>
        </form>

      </div>
    </div>
  </nav>
</header>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,500&display=swap');

  :root {
    --ink: #0d0d0d;
    --cream: #f5f0e8;
    --lime: #c8f04a;
    --border: #e2ddd4;
    --muted: #6b6b6b;
  }

  /* ── NAVBAR ── */
  .navbar {
    position: fixed;
    top: 0;
    width: 100%;
    background: rgba(245, 240, 232, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    z-index: 999;
  }

  .nav-container {
    max-width: 1280px;
    margin: auto;
    padding: 0 40px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* ── LOGO ── */
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    transition: opacity 0.18s;
  }
  .logo:hover { opacity: 0.75; }

  .logo-icon-wrap {
    width: 34px; height: 34px;
    background: var(--ink);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .logo-icon-wrap svg {
    width: 18px; height: 18px;
    fill: var(--lime);
  }

  .logo span {
    font-family: 'Syne', sans-serif;
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  /* ── RIGHT SIDE ── */
  .nav-right {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* plain nav links */
  .nav-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border-radius: 100px;
    text-decoration: none;
    color: var(--muted);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    transition: background 0.18s, color 0.18s;
    white-space: nowrap;
  }
  .nav-link:hover {
    background: white;
    color: var(--ink);
  }
  .nav-link i { font-size: 0.82rem; }

  /* ghost / outline button */
  .nav-ghost {
    display: flex;
    align-items: center;
    padding: 8px 16px;
    border-radius: 100px;
    text-decoration: none;
    color: var(--ink);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    border: 1.5px solid var(--border);
    background: transparent;
    transition: border-color 0.18s, background 0.18s;
  }
  .nav-ghost:hover {
    border-color: var(--ink);
    background: white;
  }

  /* primary CTA */
  .nav-cta {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 9px 18px;
    border-radius: 100px;
    text-decoration: none;
    background: var(--ink);
    color: var(--lime);
    font-family: 'Syne', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    transition: background 0.18s, transform 0.12s;
    white-space: nowrap;
  }
  .nav-cta:hover { background: #222; transform: translateY(-1px); }
  .nav-cta i { font-size: 0.78rem; }

  /* logout — icon only */
  .nav-logout {
    width: 36px; height: 36px;
    border-radius: 100px;
    border: 1.5px solid var(--border);
    background: transparent;
    color: var(--muted);
    font-size: 0.85rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.18s, color 0.18s, background 0.18s;
    margin-left: 4px;
  }
  .nav-logout:hover {
    border-color: #e53e3e;
    color: #e53e3e;
    background: #fff5f5;
  }

  /* ── MOBILE ── */
  @media (max-width: 640px) {
    .nav-container { padding: 0 20px; }
    .nav-link span, .nav-link { font-size: 0; padding: 8px 10px; }
    .nav-link i { font-size: 1rem; margin: 0; }
    .nav-cta { padding: 9px 14px; font-size: 0; }
    .nav-cta i { font-size: 0.9rem; }
    .nav-ghost { padding: 8px 12px; }
    .logo span { font-size: 0.95rem; }
  }
</style>
