<form action="/favourites" method="POST" class="flex justify-center">
  <input type="hidden" name="id" value="<%= home._id %>" />

  <button
    type="submit"
    class="group flex items-center justify-center gap-2 w-full max-w-xs px-6 py-2.5 rounded-full bg-green-600 text-white font-semibold text-sm shadow-md hover:bg-green-700 hover:shadow-lg hover:-translate-y-0.5 active:scale-[0.97] transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-500/40"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="currentColor"
      viewBox="0 0 24 24"
      class="w-4 h-4 group-hover:scale-110 transition"
    >
      <path d="M6 2c-1.1 0-2 .9-2 2v18l8-5 8 5V4c0-1.1-.9-2-2-2H6z" />
    </svg>

    Save Task
  </button>
</form>
