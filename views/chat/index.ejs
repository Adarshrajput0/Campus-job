<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background: #f8fafc; 
        }
        .font-heading { font-family: 'Outfit', sans-serif; }
        .message-bubble {
            max-width: 75%;
            word-wrap: break-word;
        }
        .chat-container {
            height: calc(100vh - 280px);
            overflow-y: auto;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <%- include('../partials/header', { isLoggedIn: isLoggedIn, user: user }) %>

    <main class="flex-grow max-w-4xl w-full mx-auto px-4 pt-28 pb-10 flex flex-col">
        <!-- Header -->
        <div class="bg-white rounded-t-2xl border border-slate-200 p-5 shadow-sm flex items-center justify-between">
            <div class="flex items-center gap-4">
                <a href="<%= isHost ? '/host-home-list' : '/bookings' %>" class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 hover:bg-slate-200 transition">
                    <i class="fa-solid fa-arrow-left"></i>
                </a>
                <div>
                    <h1 class="font-heading text-xl font-bold text-slate-900">
                        <%= booking.home ? booking.home.houseName : 'Task Removed' %>
                    </h1>
                    <p class="text-xs text-slate-500 mt-1">
                        <% if (isHost) { %>
                            Chat with applicant: <%= booking.user.firstName %> <%= booking.user.lastName %>
                        <% } else { %>
                            Chat with host regarding this task
                        <% } %>
                    </p>
                </div>
            </div>
            <div class="text-xs font-semibold px-3 py-1 rounded-full <%= booking.status === 'Selected' ? 'bg-amber-100 text-amber-700' : 'bg-blue-100 text-blue-700' %>">
                <%= booking.status %>
            </div>
        </div>

        <!-- Chat Box -->
        <div class="bg-slate-50 border-x border-slate-200 flex-grow chat-container p-6 space-y-4 flex flex-col" id="chatContainer">
            <% if (messages.length === 0) { %>
                <div class="m-auto text-center text-slate-400">
                    <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-3">
                        <i class="fa-regular fa-comments text-2xl"></i>
                    </div>
                    <p class="text-sm">No messages yet. Say hi!</p>
                </div>
            <% } else { %>
                <% messages.forEach(message => { 
                    const isMe = message.sender._id.toString() === user._id.toString();
                %>
                    <div class="flex w-full <%= isMe ? 'justify-end' : 'justify-start' %> group relative">
                        <div class="message-bubble <%= isMe ? 'bg-indigo-600 text-white rounded-2xl rounded-tr-sm' : 'bg-white border border-slate-200 text-slate-800 rounded-2xl rounded-tl-sm' %> px-5 py-3 shadow-sm relative">
                            <% if (!isMe) { %>
                                <p class="text-[10px] font-bold <%= isMe ? 'text-indigo-200' : 'text-slate-400' %> mb-1 uppercase tracking-wider">
                                    <%= message.sender.firstName %>
                                </p>
                            <% } %>
                            <% if (message.attachment && message.attachment.url) { %>
                                <div class="mb-2 rounded-xl overflow-hidden">
                                    <% if (message.attachment.type && message.attachment.type.startsWith('image/')) { %>
                                        <img src="<%= message.attachment.url %>" alt="attachment" class="max-w-full h-auto max-h-60 object-contain">
                                    <% } else { %>
                                        <a href="<%= message.attachment.url %>" target="_blank" class="flex items-center gap-2 bg-black/10 hover:bg-black/20 px-3 py-2 rounded-lg transition text-sm">
                                            <i class="fa-solid fa-file-arrow-down"></i> <%= message.attachment.name || 'Download File' %>
                                        </a>
                                    <% } %>
                                </div>
                            <% } %>
                            <% if (message.content) { %>
                                <p class="text-sm leading-relaxed"><%= message.content %></p>
                            <% } %>
                            <p class="text-[10px] <%= isMe ? 'text-indigo-200' : 'text-slate-400' %> mt-2 text-right">
                                <%= new Date(message.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                            </p>
                        </div>
                        <% if (isMe) { %>
                            <form action="/message/delete/<%= message._id %>" method="POST" class="absolute top-1/2 -left-10 transform -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-opacity" onsubmit="return confirm('Delete this message?')">
                                <button type="submit" class="w-8 h-8 rounded-full bg-red-50 text-red-500 hover:bg-red-100 flex items-center justify-center transition shadow-sm border border-red-100" title="Delete Message">
                                    <i class="fa-solid fa-trash text-xs"></i>
                                </button>
                            </form>
                        <% } %>
                    </div>
                <% }) %>
            <% } %>
        </div>

        <!-- Input Area -->
        <div class="bg-white rounded-b-2xl border border-slate-200 p-4 shadow-sm">
            <form action="/chat/<%= booking._id %>" method="POST" enctype="multipart/form-data" class="flex gap-3 items-center">
                <label class="cursor-pointer text-slate-400 hover:text-indigo-600 transition p-2">
                    <i class="fa-solid fa-paperclip text-xl"></i>
                    <input type="file" name="attachment" class="hidden" onchange="document.getElementById('fileName').textContent = this.files[0] ? this.files[0].name : ''">
                </label>
                <div class="flex-grow relative">
                    <input type="text" name="content" placeholder="Type a message..." class="w-full bg-slate-100 border-none rounded-xl px-5 py-3 text-sm focus:ring-2 focus:ring-indigo-500 focus:bg-white transition" autocomplete="off" autofocus>
                    <span id="fileName" class="absolute left-2 -top-5 text-[10px] font-bold text-indigo-600 truncate max-w-xs"></span>
                </div>
                <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-xl font-semibold text-sm transition shadow-sm flex items-center gap-2">
                    Send <i class="fa-solid fa-paper-plane"></i>
                </button>
            </form>
        </div>
    </main>

    <script>
        // Scroll to bottom of chat automatically
        const chatContainer = document.getElementById('chatContainer');
        chatContainer.scrollTop = chatContainer.scrollHeight;
    </script>
</body>
</html>
